---
interface Props {
  href?: string;
  label: string;
  class?: string;
  target?: string;
  rel?: string;
  outlineOnWipe?: boolean;
}

const { href, label, class: className, target, rel, outlineOnWipe = false } = Astro.props;
---

{href ? (
  <a class:list={['btn', 'surface-wipe', {'wipe-outline': outlineOnWipe}, className]} href={href} target={target} rel={rel} data-motion-control><span class="btn__label">{label}</span></a>
) : (
  <span class:list={['btn', 'surface-wipe', {'wipe-outline': outlineOnWipe}, className]} data-motion-control><span class="btn__label">{label}</span></span>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3xs) 16px;
    border-radius: var(--radius-control);
    background: var(--fg);
    color: var(--bg);
    text-decoration: none;
    backdrop-filter: blur(35px);
    -webkit-backdrop-filter: blur(35px);
    font-family: var(--font-interface);
    font-weight: 750;
    font-size: 17px;
    line-height: 1;
    letter-spacing: 0.34px;
    text-transform: uppercase;
    white-space: nowrap;
    --wipe-surface: var(--bg);
    --wipe-ink: var(--fg);
  }
</style>
