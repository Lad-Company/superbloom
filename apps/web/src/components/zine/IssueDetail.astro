---
import MediaFrame, {type Media} from '../MediaFrame.astro';
import Button from '../Button.astro';
import PinnedHorizontalRail from '../PinnedHorizontalRail.astro';
import PortableText from '../PortableText.astro';
import TagList from '../TagList.astro';
import ZineLandingIntro from './ZineLandingIntro.astro';
import ZineArticleCard from './ZineArticleCard.astro';
import PastIssues from './PastIssues.astro';
import type {TypedObject} from 'astro-portabletext/types';
import type {
  CardWidth,
  ContentCardSettingsInput,
  InfoPosition,
  MediaAspectRatio,
  PartialContentCardSettings,
} from '../../lib/contentCard';

type TextBlock = TypedObject & {children?: Array<{text?: string | null}>};
type Tag = {title?: string | null; color?: string | null};
type Article = {
  title?: string | null;
  slug?: string | null;
  overview?: TextBlock[] | null;
  publicationDate?: string | null;
  cardWidth?: CardWidth | null;
  mediaAspectRatio?: MediaAspectRatio | null;
  infoPosition?: InfoPosition | null;
  cardMedia?: Media | null;
  tags?: Tag[] | null;
};
type PastIssue = {
  title?: string | null;
  slug?: string | null;
  cardMedia?: Media | null;
};

interface Props {
  issue: {
    title?: string | null;
    slug?: string | null;
    cardMedia?: Media | null;
    heroMedia?: Media | null;
    editorLetter?: {
      labels?: string[] | null;
      heading?: string | null;
      body?: TextBlock[] | null;
      media?: Media | null;
      ctaLabel?: string | null;
    } | null;
    articles?: Article[] | null;
    listDefaults?: PartialContentCardSettings;
    articleOverrides?: Array<{articleId?: string | null} & ContentCardSettingsInput> | null;
    issuuUrl?: string | null;
    pdfUrl?: string | null;
    globalCardDefaults?: PartialContentCardSettings;
  };
  pastIssues?: PastIssue[];
  landingIntro?: {
    heading?: string | null;
    imageLayers?: Media[] | null;
    fallbackMedia?: Media[];
    ctaLabel?: string | null;
    ctaHref: string;
  };
}

const {issue, pastIssues = [], landingIntro} = Astro.props;
const articles = issue.articles ?? [];
const editorLetterLabels = issue.editorLetter?.labels?.map((title) => ({title}));
const readZineHref = issue.pdfUrl ?? issue.issuuUrl ?? null;
const overrideFor = (id?: string | null) =>
  issue.articleOverrides?.find((override) => override.articleId === id);
---

<article class="issue-detail">
  <header class="hero">
    <div class="hero-media">
      <MediaFrame
        media={issue.heroMedia}
        ratio="16:9"
        title={issue.title}
        priority
      />
    </div>
    <div class="hero-copy">
      <h1 class="type-h1">{issue.title}</h1>
      {readZineHref && <a class="explore" href={readZineHref} target="_blank" rel="noopener noreferrer">Explore the Issue</a>}
    </div>
  </header>

  {landingIntro && <ZineLandingIntro {...landingIntro} />}

  {issue.editorLetter && (
    <section class="editor-letter" aria-labelledby="editor-letter-heading">
      <div class="editor-letter-media">
        <MediaFrame
          media={issue.editorLetter.media ?? issue.heroMedia}
          ratio="1:1"
          title={issue.editorLetter.heading}
        >
          <TagList slot="overlay" tags={editorLetterLabels} />
        </MediaFrame>
      </div>
      <div class="editor-letter-copy">
        <h2 id="editor-letter-heading" class="type-h3">{issue.editorLetter.heading}</h2>
        {issue.editorLetter.body && <PortableText value={issue.editorLetter.body} class="type-body" />}
        {issue.editorLetter.ctaLabel && readZineHref && (
          <Button
            href={readZineHref}
            label={issue.editorLetter.ctaLabel}
            outlineOnWipe
            target="_blank"
            rel="noopener noreferrer"
          />
        )}
      </div>
    </section>
  )}

  <section class="stories" aria-labelledby="stories-heading">
    <h2 id="stories-heading" class="type-h3">More stories</h2>
    {
      issue.slug && (
        <PinnedHorizontalRail class="article-rail" label="More stories" showControls>
          {articles.map((article) => (
            <ZineArticleCard
              article={article}
              issueSlug={issue.slug!}
              settings={overrideFor((article as {_id?: string})._id)}
              listSettings={issue.listDefaults}
              globalSettings={issue.globalCardDefaults}
            />
          ))}
        </PinnedHorizontalRail>
      )
    }
  </section>

  <PastIssues issues={pastIssues} />

</article>

<style>
  .hero {
    position: relative;
    color: #fff;
    background: #000;
  }

  .hero-media :global(.media-frame) {
    max-height: 90svh;
    border-radius: 0;
  }

  .hero-copy {
    position: absolute;
    right: var(--page-inset);
    bottom: var(--space-xl);
    left: var(--page-inset);
    max-width: 900px;
  }

  .explore {
    display: inline-flex;
    margin-top: var(--space-xs);
    padding: var(--space-3xs) 16px;
    border-radius: var(--radius-control);
    background: #fff;
    color: #000;
    font-family: var(--font-interface);
    font-weight: 750;
    text-decoration: none;
    text-transform: uppercase;
  }

  h1,
  h2 {
    margin: 0;
  }

  .editor-letter {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    align-items: center;
    gap: clamp(var(--space-l), 10vw, var(--space-4xl));
    padding: clamp(var(--space-3xl), 14vw, 240px) var(--page-inset);
    background: #c3e4d3;
    color: #000;
  }

  .editor-letter-copy {
    display: flex;
    flex-direction: column;
    align-items: start;
    gap: var(--space-2xs);
    max-width: 540px;
  }

  .editor-letter-copy :global(.portable-text) {
    max-width: 480px;
  }

  .editor-letter-copy :global(.portable-text p) {
    margin: 0;
  }

  .editor-letter-media :global(.tag-list) {
    --bg: #000;
    --border-subtle: 0;
    --frosted-layer: #000;
  }

  .stories {
    padding: var(--space-4xl) var(--page-inset);
    --bg: #000;
    --fg: #fff;
    --fg-60: rgba(255, 255, 255, 0.6);
    color: var(--fg);
    background: var(--bg);
  }

  :global(.article-rail) {
    margin-top: var(--space-xl);
  }

  :global(.article-rail .controls) {
    position: absolute;
    top: calc(-1 * (var(--space-xl) + var(--space-xs-4)));
    right: 0;
    margin: 0;
    padding: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .editor-letter {
      grid-template-columns: 1fr;
      gap: var(--space-m);
      padding-block: var(--space-xl);
    }

    .editor-letter-copy {
      max-width: none;
    }

    :global(.article-rail .controls) {
      position: static;
      justify-content: flex-start;
      margin-top: var(--space-xs);
    }
  }

</style>

