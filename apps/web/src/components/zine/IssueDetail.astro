---
import MediaFrame, {type Media, type MediaRatio} from '../MediaFrame.astro';
import PortableText from '../PortableText.astro';
import ZineArticleCard from './ZineArticleCard.astro';
import PastIssues from './PastIssues.astro';
import type {TypedObject} from 'astro-portabletext/types';

type TextBlock = TypedObject & {children?: Array<{text?: string | null}>};
type Tag = {title?: string | null; color?: string | null};
type Article = {
  title?: string | null;
  slug?: string | null;
  overview?: TextBlock[] | null;
  cardAspectRatio?: MediaRatio | null;
  cardMedia?: Media | null;
  tags?: Tag[] | null;
};
type PastIssue = {
  issueNumber?: number | null;
  title?: string | null;
  slug?: string | null;
  coverAspectRatio?: MediaRatio | null;
  cardMedia?: Media | null;
};

interface Props {
  issue: {
    issueNumber?: number | null;
    title?: string | null;
    slug?: string | null;
    coverAspectRatio?: MediaRatio | null;
    cardMedia?: Media | null;
    heroMedia?: Media | null;
    introHeadline?: string | null;
    introText?: TextBlock[] | null;
    introMedia?: Media[] | null;
    editorLetter?: {headline?: string | null; body?: TextBlock[] | null; media?: Media | null} | null;
    articles?: Article[] | null;
    issuuUrl?: string | null;
  };
  pastIssues?: PastIssue[];
}

const {issue, pastIssues = []} = Astro.props;
const articles = issue.articles ?? [];
const introMedia = issue.introMedia ?? [];
const hasIntro = Boolean(issue.introHeadline || issue.introText || introMedia.length > 0);
const issuuEmbedUrl = (() => {
  if (!issue.issuuUrl) return null;

  try {
    const url = new URL(issue.issuuUrl);
    if (url.hostname === 'e.issuu.com') return url.toString();

    const [, publisher, docs, publication] = url.pathname.split('/');
    if (docs === 'docs' && publisher && publication) {
      const params = new URLSearchParams({d: publication, u: publisher});
      return `https://e.issuu.com/embed.html?${params}`;
    }
  } catch {
    return null;
  }

  return issue.issuuUrl;
})();
---

<article class="issue-detail">
  <header class="hero">
    <MediaFrame
      media={issue.heroMedia}
      ratio="16:9"
      title={issue.title}
      priority
    />
    <div class="hero-copy">
      {issue.issueNumber && <p class="type-h4">Issue No. {issue.issueNumber}</p>}
      <h1 class="type-h1">{issue.title}</h1>
      <a class="explore" href={hasIntro ? '#issue-intro' : '#flipbook'}>Explore the Issue</a>
    </div>
  </header>

  {hasIntro && (
    <section id="issue-intro" class="intro" aria-labelledby="intro-heading">
    <div class="intro-copy">
      {issue.introHeadline && <h2 id="intro-heading" class="type-h3">{issue.introHeadline}</h2>}
      {issue.introText && <PortableText value={issue.introText} class="type-h5" />}
    </div>
    <div class="collage" aria-hidden="true">
      {introMedia.map((media, index) => (
        <MediaFrame media={media} ratio={index === 2 || index === 4 ? '3:2' : '1:1'} />
      ))}
    </div>
    </section>
  )}

  {issue.editorLetter && (
    <section class="editor-letter" aria-labelledby="editor-letter-heading">
      {issue.editorLetter.media && (
        <MediaFrame media={issue.editorLetter.media} ratio="4:5" title={issue.editorLetter.headline} />
      )}
      <div>
        <h2 id="editor-letter-heading" class="type-h3">
          {issue.editorLetter.headline ?? 'Letter from the Editor'}
        </h2>
        {issue.editorLetter.body && <PortableText value={issue.editorLetter.body} />}
      </div>
    </section>
  )}

  {issuuEmbedUrl && (
    <section id="flipbook" class="flipbook" aria-labelledby="flipbook-heading">
      <h2 id="flipbook-heading" class="type-h3">Read the Zine</h2>
      <iframe
        src={issuuEmbedUrl}
        title={`${issue.title ?? 'Zine'} flipbook`}
        allow="clipboard-write; fullscreen"
        allowfullscreen
        loading="lazy"
      />
    </section>
  )}

  <section class="stories" aria-labelledby="stories-heading">
    <h2 id="stories-heading" class="type-h3">More stories</h2>
    {
      issue.slug && (
        <ul class="article-grid">
          {articles.map((article) => (
            <li><ZineArticleCard article={article} issueSlug={issue.slug!} /></li>
          ))}
        </ul>
      )
    }
  </section>

  <PastIssues issues={pastIssues} />

</article>

<style>
  .hero {
    position: relative;
    color: #fff;
    background: #000;
  }

  .hero :global(.media-frame) {
    max-height: 90svh;
    border-radius: 0;
  }

  .hero-copy {
    position: absolute;
    right: var(--page-inset);
    bottom: var(--space-xl);
    left: var(--page-inset);
    max-width: 900px;
  }

  .explore {
    display: inline-flex;
    margin-top: var(--space-xs);
    padding: var(--space-3xs) 16px;
    border-radius: var(--radius-control);
    background: #fff;
    color: #000;
    font-family: var(--font-interface);
    font-weight: 750;
    text-decoration: none;
    text-transform: uppercase;
  }

  .hero-copy p,
  h1,
  h2 {
    margin: 0;
  }

  .intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--page-gutter);
    padding: var(--space-4xl) var(--page-inset);
    color: #fff;
    background: #000;
  }

  #issue-intro {
    scroll-margin-top: var(--space-xl);
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(html) {
      scroll-behavior: smooth;
    }
  }

  .intro-copy {
    display: flex;
    flex-direction: column;
    justify-content: end;
    gap: var(--space-xs);
    max-width: 720px;
  }

  .collage {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xs-4);
    align-content: start;
  }

  .collage :global(.media-frame):nth-child(1) {
    grid-row: span 2;
  }

  .collage :global(.media-frame):nth-child(4) {
    grid-column: span 2;
  }

  .editor-letter {
    display: grid;
    grid-template-columns: minmax(280px, 1fr) minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: start;
    padding: var(--space-4xl) var(--page-inset);
    background: #c3e4d3;
    color: #000;
  }

  .editor-letter > div {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    max-width: 640px;
  }

  .read-zine {
    font-family: var(--font-interface);
    font-weight: 750;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .flipbook {
    padding: var(--space-4xl) var(--page-inset);
    background: #000;
    color: #fff;
  }

  .flipbook iframe {
    width: 100%;
    height: min(80svh, 900px);
    margin-top: var(--space-xl);
    border: 0;
  }

  .stories {
    padding: var(--space-4xl) var(--page-inset);
    color: #fff;
    background: #000;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--page-gutter);
    margin-top: var(--space-xl);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 1023px) {
    .intro,
    .editor-letter {
      grid-template-columns: 1fr;
    }

    .article-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
