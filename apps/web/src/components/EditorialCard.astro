---
import MediaFrame, { type Media, type MediaRatio } from './MediaFrame.astro';

interface Props {
  href: string;
  title: string | null;
  media: Media | null;
  aspectRatio?: MediaRatio | null;
  summary?: string | null;
  publicationDate?: string | null;
  class?: string;
  target?: string;
  rel?: string;
  externalLabel?: string;
}

const { href, title, media, aspectRatio, summary, publicationDate, class: className, target, rel, externalLabel } = Astro.props;
const formattedDate = publicationDate
  ? new Intl.DateTimeFormat('en-US', {year: 'numeric', month: 'long', day: 'numeric'}).format(
      new Date(publicationDate),
    )
  : null;
---

<a class:list={['editorial-card', className]} href={href} target={target} rel={rel}>
  <MediaFrame media={media} ratio={aspectRatio} title={title}>
    <slot name="overlay" />
  </MediaFrame>
  <div class="content">
    {title && <p class="headline type-h6">{title}</p>}
    {summary && <p class="summary type-caption">{summary}</p>}
    {formattedDate && <time class="publication-date type-caption" datetime={publicationDate}>{formattedDate}</time>}
    {externalLabel && (
      <p class="external-label type-caption">
        {externalLabel} <span aria-hidden="true">↗</span>
      </p>
    )}
  </div>
</a>

<style>
  .editorial-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    min-width: 0;
    color: var(--fg);
    text-decoration: none;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs-4);
  }

  .headline,
  .summary {
    margin: 0;
  }

  .summary {
    color: var(--fg-60);
  }

  .external-label {
    margin: 0;
  }

  .publication-date {
    color: var(--fg-60);
  }
</style>
