---
import MediaFrame, { type Media, type MediaRatio } from './MediaFrame.astro';
import {
  resolveContentCardSettings,
  type PartialContentCardSettings,
} from '../lib/contentCard';
import { formatPublicationDate } from '../lib/publicationDate';

interface Props {
  href: string;
  title: string | null;
  media: Media | null;
  summary?: string | null;
  publicationDate?: string | null;
  class?: string;
  target?: string;
  rel?: string;
  externalLabel?: string;
  ctaLabel?: string | null;
  cardId?: string | null;
  contentSettings?: PartialContentCardSettings;
  settings?: PartialContentCardSettings;
  listSettings?: PartialContentCardSettings;
  globalSettings?: PartialContentCardSettings;
}

const {
  href,
  title,
  media,
  summary,
  publicationDate,
  class: className,
  target,
  rel,
  externalLabel,
  ctaLabel,
  cardId,
  contentSettings,
  settings,
  listSettings,
  globalSettings,
} = Astro.props;
const resolved = resolveContentCardSettings({
  global: globalSettings,
  content: contentSettings,
  list: listSettings,
  item: settings,
});
const formattedDate = publicationDate ? formatPublicationDate(publicationDate) : null;
---

<a
  class:list={['editorial-card', 'content-card', className]}
  href={href}
  target={target}
  rel={rel}
  data-card-width={resolved.cardWidth}
  data-info-position={resolved.infoPosition}
  data-content-card-id={cardId}
>
  <MediaFrame media={media} ratio={resolved.mediaAspectRatio as MediaRatio} title={title}>
    <slot name="overlay" />
  </MediaFrame>
  <div class="content">
    {title && <p class="headline type-h6">{title}</p>}
    {summary && <p class="summary type-caption">{summary}</p>}
    {formattedDate && (
      <time class="publication-date type-caption" datetime={formattedDate.dateTime}>
        {formattedDate.label}
      </time>
    )}
    {externalLabel && (
      <p class="external-label type-caption">
        {externalLabel} <span aria-hidden="true">↗</span>
      </p>
    )}
    {ctaLabel && <span class="cta type-caption">{ctaLabel}</span>}
  </div>
</a>

<style>
  .editorial-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    min-width: 0;
    color: var(--fg);
    text-decoration: none;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs-4);
  }

  .editorial-card[data-info-position='left'],
  .editorial-card[data-info-position='right'] {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: start;
    gap: var(--page-gutter);
  }

  .editorial-card[data-info-position='left'] .content {
    grid-column: 1;
    grid-row: 1;
  }

  .editorial-card[data-info-position='left'] :global(.media-frame) {
    grid-column: 2;
  }

  .headline,
  .summary {
    margin: 0;
  }

  .headline {
    font-family: var(--font-body);
    font-size: 24px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .summary {
    color: var(--fg-60);
  }

  .external-label {
    margin: 0;
  }

  .cta {
    align-self: start;
    margin-top: var(--space-xs-4);
    padding: var(--space-3xs) 16px;
    border-radius: var(--radius-control);
    background: #fff;
    color: #000;
    box-shadow: inset 0 0 0 1px #000;
    font-family: var(--font-interface);
    font-size: 17px;
    font-weight: 750;
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    transition:
      background var(--motion-quick) var(--motion-ease-out),
      color var(--motion-quick) var(--motion-ease-out),
      box-shadow var(--motion-quick) var(--motion-ease-out);
  }

  .editorial-card:hover .cta,
  .editorial-card:focus-visible .cta {
    background: #000;
    color: #fff;
    box-shadow: inset 0 0 0 1px #fff;
  }

  .publication-date {
    color: var(--fg-60);
  }

  .editorial-card:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
  }

  @media (max-width: 1023px) {
    .editorial-card[data-info-position='left'],
    .editorial-card[data-info-position='right'] {
      display: flex;
      flex-direction: column;
      gap: var(--space-3xs);
    }
  }
</style>
