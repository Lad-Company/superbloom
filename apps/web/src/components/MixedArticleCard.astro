---
import NewsCard from './NewsCard.astro';
import EditorialArticleCard from './EditorialArticleCard.astro';
import ZineArticleCard from './zine/ZineArticleCard.astro';
import type {Media} from './MediaFrame.astro';
import type {TypedObject} from 'astro-portabletext/types';
import type {
  CardWidth,
  InfoPosition,
  MediaAspectRatio,
  PartialContentCardSettings,
} from '../lib/contentCard';

interface Item {
  _id?: string | null;
  articleType?: 'news' | 'editorial' | 'zine' | null;
  title: string | null;
  slug: string | null;
  issueSlug?: string | null;
  overview?: Array<TypedObject & {children?: Array<{text?: string | null}>}> | null;
  publicationDate?: string | null;
  cardDestination?: 'internal' | 'external' | null;
  externalCoverage?: Array<{url?: string | null; isPrimary?: boolean | null}> | null;
  cardWidth?: CardWidth | null;
  mediaAspectRatio?: MediaAspectRatio | null;
  infoPosition?: InfoPosition | null;
  tags: Array<{title?: string | null; color?: string | null}> | null;
  cardMedia: Media | null;
}

interface Props {
  item: Item;
  settings?: PartialContentCardSettings;
  listSettings?: PartialContentCardSettings;
  globalSettings?: PartialContentCardSettings;
  showCopy?: boolean;
}

const {item, settings, listSettings, globalSettings, showCopy = false} = Astro.props;
---

{item.articleType === 'news' ? (
  <NewsCard item={item} settings={settings} listSettings={listSettings} globalSettings={globalSettings} mixedList showCopy={showCopy} />
) : item.articleType === 'zine' ? (
  item.issueSlug && (
    <ZineArticleCard article={item} issueSlug={item.issueSlug} settings={settings} listSettings={listSettings} globalSettings={globalSettings} mixedList />
  )
) : item.articleType === 'editorial' ? (
  <EditorialArticleCard item={item} settings={settings} listSettings={listSettings} globalSettings={globalSettings} mixedList showCopy={showCopy} />
) : null}
