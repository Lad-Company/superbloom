---
interface Props {
  role?: 'light' | 'dark' | 'surface';
  logoVariant?: 'light' | 'dark';
}

const { role = 'light', logoVariant = role === 'light' ? 'light' : 'dark' } = Astro.props;
const logoSrc = logoVariant === 'light'
  ? '/superbloom-house-logo.svg'
  : '/superbloom-house-logo-black.svg';
const links = [
  { label: 'Our Work', href: '/work' },
  { label: 'Who We Are', href: '/who-we-are' },
  { label: 'News & Press', href: '/index' },
  { label: 'Zine', href: '/zine' },
];
---

<nav class:list={['navigation', role]} aria-label="Primary navigation">
  <a href="/" class="logo" data-route-link aria-label="Superbloom House">
    <img src={logoSrc} alt="" width="697" height="41" />
  </a>
  <ul class="desktop-links">
    {
      links.map((link) => (
        <li>
          <a href={link.href} class="type-eyebrow underline-draw" data-route-link>{link.label}</a>
        </li>
      ))
    }
  </ul>
  <div class="desktop-actions">
    <a href="#contact" class:list={['btn', 'btn-secondary', 'surface-wipe', 'type-label', {'wipe-outline': role === 'surface'}]} data-motion-control><span class="nav__label">Let's Chat</span></a>
    <a href="/shop" class="btn btn-tertiary surface-wipe type-label" data-motion-control><span class="nav__label">Shop</span></a>
    <a href="/cart" class="cart-link underline-draw type-label" data-cart-link hidden aria-label="Cart, 0 items">Cart <span data-cart-count>0</span></a>
  </div>
  <details class="compact-menu">
    <summary class="type-label">Menu</summary>
    <div class="compact-panel">
      <ul>
        {
          links.map((link) => (
            <li>
              <a href={link.href} class="type-label underline-draw" data-route-link>{link.label}</a>
            </li>
          ))
        }
      </ul>
      <a href="#contact" class:list={['btn', 'btn-secondary', 'surface-wipe', 'type-label', {'wipe-outline': role === 'surface'}]} data-motion-control><span class="nav__label">Let's Chat</span></a>
      <a href="/shop" class="btn btn-tertiary surface-wipe type-label" data-motion-control><span class="nav__label">Shop</span></a>
      <a href="/cart" class="type-label underline-draw" data-cart-link hidden aria-label="Cart, 0 items">Cart <span data-cart-count>0</span></a>
    </div>
  </details>
</nav>

<script>
  const counts = document.querySelectorAll<HTMLElement>('[data-cart-count]');
  const cartLinks = document.querySelectorAll<HTMLAnchorElement>('[data-cart-link]');

  const updateCartLinks = (itemCount: number) => {
    const isActive = itemCount > 0;
    counts.forEach((count) => { count.textContent = String(itemCount); });
    cartLinks.forEach((link) => {
      link.hidden = !isActive;
      link.setAttribute('aria-label', `Cart, ${itemCount} ${itemCount === 1 ? 'item' : 'items'}`);
    });
  };

  const refreshCartCount = async () => {
    try {
      const response = await fetch('/api/shop/cart/get.json');
      if (!response.ok) return;
      const cart = await response.json();
      updateCartLinks(cart.itemCount);
    } catch {}
  };
  refreshCartCount();
  document.addEventListener('shop:cart-updated', refreshCartCount);
</script>

<style>
  .navigation {
    position: absolute;
    inset: 0 0 auto;
    z-index: 10;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    padding: 19px var(--page-gutter);
    width: 100%;
  }
  .light { color: #ffffff; }
  .dark { color: #000000; }
  .surface { color: var(--fg); }
  .logo,
  a { text-decoration: none; }
  .logo {
    flex-shrink: 0;
    width: 248px;
  }
  .logo img {
    display: block;
    width: 100%;
    height: auto;
  }
  .desktop-links,
  .desktop-actions {
    display: flex;
    align-items: center;
  }
  .desktop-links {
    justify-content: space-evenly;
    gap: 0;
  }
  .desktop-actions {
    gap: var(--space-3xs);
    flex-shrink: 0;
    justify-self: end;
  }
  .btn {
    padding: var(--space-3xs) 16px;
    border-radius: var(--radius-control);
    backdrop-filter: blur(var(--frosted-layer-blur));
    -webkit-backdrop-filter: blur(var(--frosted-layer-blur));
  }
  .cart-link { text-decoration: none; }
  .light .btn-secondary {
    background: #ffffff;
    color: #000000;
    --wipe-surface: #000000;
    --wipe-ink: #ffffff;
  }
  .light .btn-tertiary {
    background: rgba(255, 255, 255, 0.2);
    color: #ffffff;
    --wipe-surface: #ffffff;
    --wipe-ink: #000000;
  }
  .dark .btn-secondary {
    background: #000000;
    color: #ffffff;
    --wipe-surface: #ffffff;
    --wipe-ink: #000000;
  }
  .dark .btn-tertiary {
    background: rgba(0, 0, 0, 0.2);
    color: #000000;
    --wipe-surface: #000000;
    --wipe-ink: #ffffff;
  }
  .surface .btn-secondary {
    background: var(--fg);
    color: var(--bg);
    --wipe-surface: var(--bg);
    --wipe-ink: var(--fg);
  }
  .surface .btn-tertiary {
    background: var(--fg-12);
    color: var(--fg);
    --wipe-surface: var(--fg);
    --wipe-ink: var(--bg);
  }
  .compact-menu { display: none; }

  @media (max-width: 1023px) {
    .navigation {
      display: flex;
      justify-content: space-between;
      padding: var(--space-2xs);
    }
    .desktop-links,
    .desktop-actions { display: none; }
    .compact-menu {
      display: block;
      position: relative;
    }
    .compact-menu summary {
      cursor: pointer;
      list-style: none;
      padding: var(--space-3xs) 16px;
      border: 1px solid currentColor;
      border-radius: var(--radius-control);
    }
    .compact-menu summary::-webkit-details-marker { display: none; }
    .compact-panel {
      position: absolute;
      top: calc(100% + var(--space-3xs));
      right: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-3xs);
      min-width: 220px;
      padding: var(--space-2xs);
      background: var(--bg);
      color: var(--fg);
      border-radius: var(--radius-input);
    }
    .compact-panel ul {
      display: flex;
      flex-direction: column;
      gap: var(--space-2xs);
    }
    .compact-panel .btn { text-align: center; }
    .compact-panel .btn-secondary {
      background: var(--fg);
      color: var(--bg);
      --wipe-surface: var(--bg);
      --wipe-ink: var(--fg);
    }
    .compact-panel .btn-tertiary {
      background: var(--fg-12);
      color: var(--fg);
      --wipe-surface: var(--fg);
      --wipe-ink: var(--bg);
    }
  }

  @media (max-width: 767px) {
    .navigation { padding: var(--space-3xs); }
    .logo { max-width: 13ch; }
  }
</style>
