---
import Card from './Card.astro';

interface Tag {
  title: string | null;
  color: string | null;
}

interface Media {
  _type: 'image' | 'mux.video';
  url?: string | null;
  width?: number | null;
  height?: number | null;
  alt?: string | null;
  playbackId?: string | null;
}

interface NewsItem {
  title: string | null;
  slug: string | null;
  summary: string | null;
  aspectRatio: '1:1' | '16:9' | '4:5' | null;
  tags: Tag[] | null;
  media: Media | null;
}

interface Props {
  item: NewsItem;
  size?: 'large' | 'small';
  showCopy?: boolean;
}

const { item, size = 'small', showCopy = false } = Astro.props;
const href = item.slug ? `/news/${item.slug}` : '#';
---

<Card
  href={href}
  title={item.title}
  media={item.media}
  aspectRatio={item.aspectRatio}
  tags={item.tags}
  summary={item.summary}
  size={size}
  showSummary={showCopy}
/>
