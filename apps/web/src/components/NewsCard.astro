---
import EditorialCard from './EditorialCard.astro';
import TagList from './TagList.astro';
import type { Media, MediaRatio } from './MediaFrame.astro';

interface Tag {
  title: string | null;
  color: string | null;
}

interface NewsItem {
  title: string | null;
  slug: string | null;
  overview?: Array<{ children?: Array<{ text?: string | null }> }> | null;
  publicationDate?: string | null;
  isExternal?: boolean | null;
  externalUrl?: string | null;
  externalCoverage?: Array<{ url?: string | null; isPrimary?: boolean | null }> | null;
  cardAspectRatio: MediaRatio | null;
  tags: Tag[] | null;
  cardMedia: Media | null;
}

interface Props {
  item: NewsItem;
  showCopy?: boolean;
  class?: string;
}

const { item, showCopy = false, class: className } = Astro.props;
const internalHref = item.slug ? `/news/${item.slug}` : '#';
const href = item.isExternal && item.externalUrl ? item.externalUrl : internalHref;
const opensInNewTab = item.isExternal && Boolean(item.externalUrl);
const summary = item.overview
  ?.flatMap((block) => block.children?.map((child) => child.text ?? '') ?? [])
  .join(' ')
  .trim();
---

<div class:list={['news-card', className]}>
  <EditorialCard
    href={href}
    title={item.title}
    media={item.cardMedia}
    aspectRatio={item.cardAspectRatio}
    summary={showCopy ? summary : undefined}
    publicationDate={item.publicationDate}
    target={opensInNewTab ? '_blank' : undefined}
    rel={opensInNewTab ? 'noopener noreferrer' : undefined}
    externalLabel={opensInNewTab ? 'Read externally (opens in a new tab)' : undefined}
  >
    <TagList slot="overlay" tags={item.tags} />
  </EditorialCard>
</div>

<style>
  .news-card {
    min-width: 0;
  }
</style>
