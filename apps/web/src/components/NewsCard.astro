---
import EditorialCard from './EditorialCard.astro';
import TagList from './TagList.astro';
import type { Media } from './MediaFrame.astro';
import {
  type CardWidth,
  type InfoPosition,
  type MediaAspectRatio,
  type PartialContentCardSettings,
} from '../lib/contentCard';

interface Tag {
  title?: string | null;
  color?: string | null;
}

interface NewsItem {
  _id?: string | null;
  title: string | null;
  slug: string | null;
  overview?: Array<{ children?: Array<{ text?: string | null }> }> | null;
  publicationDate?: string | null;
  cardDestination?: 'internal' | 'external' | null;
  externalCoverage?: Array<{ url?: string | null; isPrimary?: boolean | null }> | null;
  cardWidth?: CardWidth | null;
  mediaAspectRatio?: MediaAspectRatio | null;
  infoPosition?: InfoPosition | null;
  tags: Tag[] | null;
  cardMedia: Media | null;
}

interface Props {
  item: NewsItem;
  showCopy?: boolean;
  class?: string;
  settings?: PartialContentCardSettings;
  listSettings?: PartialContentCardSettings;
  globalSettings?: PartialContentCardSettings;
  mixedList?: boolean;
}

const {
  item,
  showCopy = false,
  class: className,
  settings,
  listSettings,
  globalSettings,
  mixedList = false,
} = Astro.props;
const internalHref = item.slug ? `/news/${item.slug}` : '#';
const primaryCoverage = item.externalCoverage?.find((coverage) => coverage.isPrimary && coverage.url);
const opensInNewTab = item.cardDestination === 'external' && Boolean(primaryCoverage?.url);
const href = opensInNewTab ? primaryCoverage!.url! : internalHref;
const summary = item.overview
  ?.flatMap((block) => block.children?.map((child) => child.text ?? '') ?? [])
  .join(' ')
  .trim();
---

<EditorialCard
  href={href}
  title={item.title}
  media={item.cardMedia}
  contentSettings={item}
  settings={settings}
  listSettings={listSettings}
  globalSettings={globalSettings}
  summary={showCopy ? summary : undefined}
  publicationDate={item.publicationDate}
  class={className}
  target={opensInNewTab ? '_blank' : undefined}
  rel={opensInNewTab ? 'noopener noreferrer' : undefined}
  externalLabel={opensInNewTab ? 'Read externally (opens in a new tab)' : undefined}
  cardId={item._id}
>
  <TagList slot="overlay" tags={item.tags} typeLabel={mixedList ? 'News' : undefined} maxTags={mixedList ? 1 : 2} />
</EditorialCard>
