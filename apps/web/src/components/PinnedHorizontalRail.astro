---
interface Props {
  label: string;
  class?: string;
  showControls?: boolean;
}

const { label, class: className, showControls = false } = Astro.props;
---

<section class:list={['pinned-horizontal-rail', className]} data-pinned-horizontal-rail aria-label={label}>
  <div class="rail" data-rail>
    <div class="track" data-track role="region" tabindex="0" aria-label={label}>
      <slot />
    </div>
    {showControls && (
      <div class="controls" aria-label={`${label} controls`}>
        <button class="control previous" type="button" aria-label={`Previous ${label}`}>←</button>
        <button class="control next" type="button" aria-label={`Next ${label}`}>→</button>
      </div>
    )}
  </div>
</section>

<script>
  import { initHorizontalRail } from '../lib/motion';

  const cleanups: Array<() => void> = [];

  const initRails = () => document.querySelectorAll<HTMLElement>('[data-pinned-horizontal-rail]').forEach((section) => {
    if (section.dataset.railInitialized) return;
    const rail = section.querySelector<HTMLElement>('[data-rail]');
    const track = section.querySelector<HTMLElement>('[data-track]');
    if (!rail || !track) return;
    section.dataset.railInitialized = 'true';

    const horizontalRail = initHorizontalRail(section, rail, track);
    const scrollCards = (direction: -1 | 1) => {
      if (section.classList.contains('is-scroll-jacked')) {
        direction === -1 ? horizontalRail.previous() : horizontalRail.next();
        return;
      }
      const amount = (track.firstElementChild as HTMLElement | null)?.offsetWidth ?? 0;
      track.scrollBy({left: direction * amount, behavior: 'smooth'});
    };
    const previous = () => scrollCards(-1);
    const next = () => scrollCards(1);
    section.querySelector('.previous')?.addEventListener('click', previous);
    section.querySelector('.next')?.addEventListener('click', next);

    cleanups.push(() => {
      horizontalRail.destroy();
      section.querySelector('.previous')?.removeEventListener('click', previous);
      section.querySelector('.next')?.removeEventListener('click', next);
      delete section.dataset.railInitialized;
    });
  });

  initRails();
  window.addEventListener('pagehide', () => cleanups.splice(0).forEach((cleanup) => cleanup()));
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) initRails();
  });
</script>

<style>
  .pinned-horizontal-rail {
    display: block;
  }

  .rail {
    position: relative;
    overflow: hidden;
  }

  .track {
    display: flex;
    gap: var(--page-gutter);
    overflow-x: auto;
    padding-right: var(--space-xs);
    scroll-snap-type: x proximity;
    scrollbar-width: none;
  }

  .track::-webkit-scrollbar {
    display: none;
  }

  .is-scroll-jacked .track {
    overflow: visible;
    scroll-snap-type: none;
  }

  .track > :global(.content-card) {
    flex: 0 0 auto;
    scroll-snap-align: start;
  }

  .track > :global(.content-card[data-card-width='1/4']) {
    width: min(23.3vw, 335px);
  }

  .track > :global(.content-card[data-card-width='1/3']) {
    width: min(30.75vw, 443px);
  }

  .track > :global(.content-card[data-card-width='1/2']) {
    width: min(44vw, 634px);
  }

  .track > :global(.content-card[data-card-width='2/3']) {
    width: min(58vw, 835px);
  }

  .track > :global(.content-card[data-card-width='3/4']) {
    width: min(70vw, 1008px);
  }

  .track > :global(.content-card[data-card-width='full']) {
    width: min(88vw, 1267px);
  }

  .pinned-horizontal-rail.news-rail .track > :global(.content-card:first-child) {
    width: min(31.3vw, 451px);
  }

  .pinned-horizontal-rail.news-rail .track > :global(.content-card:not(:first-child)) {
    width: min(23.3vw, 335px);
  }

  .controls {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-3xs);
    margin-top: var(--space-2xs);
    padding-right: var(--space-xs);
  }

  .control {
    width: 40px;
    height: 40px;
    border: 1px solid color-mix(in srgb, var(--fg) 30%, transparent);
    border-radius: var(--radius-control);
    background: transparent;
    color: inherit;
    cursor: pointer;
  }

  .control:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  @media (max-width: 959px) {
    .track {
      gap: 16px;
    }

    .track > :global(.content-card[data-card-width]) {
      width: min(56vw, 360px);
    }

    .pinned-horizontal-rail.news-rail .track > :global(.content-card:first-child),
    .pinned-horizontal-rail.news-rail .track > :global(.content-card:not(:first-child)) {
      width: min(56vw, 360px);
    }
  }

  @media (max-width: 599px) {
    .track {
      gap: 12px;
      padding-right: 12px;
    }

    .track > :global(.content-card[data-card-width]) {
      width: min(76vw, 280px);
    }

    .pinned-horizontal-rail.news-rail .track > :global(.content-card:first-child),
    .pinned-horizontal-rail.news-rail .track > :global(.content-card:not(:first-child)) {
      width: min(76vw, 280px);
    }

    .controls {
      padding-right: 12px;
    }
  }
</style>
