---
import MediaFrame, {type Media} from './MediaFrame.astro';
import Button from './Button.astro';

interface Cta {
  _key?: string;
  heading: string | null;
  label?: string | null;
  href?: string | null;
  media?: Media | null;
}

interface Props {
  items: Cta[];
}

const { items } = Astro.props;
---

<div class="two-up">
  {items.map((item) => (
    <div class="col">
      <MediaFrame media={item.media} ratio="1:1" title={item.heading ?? undefined} />
      {item.heading && <p class="heading type-h5">{item.heading}</p>}
      {item.label && (
        <Button href={item.href ?? '#'} label={item.label} />
      )}
    </div>
  ))}
</div>

<style>
  .two-up {
    display: flex;
    gap: var(--page-gutter);
    padding: var(--space-4xl) var(--space-xs);
    align-items: flex-start;
  }
  .col {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .col :global(.btn) {
    align-self: flex-start;
  }
  .col :global(.media-frame) {
    border-radius: var(--radius-s);
  }
  .heading {
    margin: 0;
  }
  @media (max-width: 768px) {
    .two-up {
      flex-direction: column;
      padding: var(--space-2xl) var(--space-3xs);
    }
  }
</style>
