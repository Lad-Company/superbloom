---
import MediaFrame, {type Media, type MediaRatio} from './MediaFrame.astro';

interface Props {
  heading: string | null;
  body?: string | null;
  media?: Media | null;
  aspectRatio?: MediaRatio | null;
}

const { heading, body, media, aspectRatio = '1:1' } = Astro.props;
---

<div class="text-media">
  <div class="text-col">
    {heading && <p class="heading type-h4">{heading}</p>}
    {body && <p class="body type-h6">{body}</p>}
  </div>
  <div class="media-col">
    <MediaFrame media={media} ratio={aspectRatio} title={heading ?? undefined} />
  </div>
</div>

<style>
  .text-media {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    padding: var(--space-4xl) var(--space-xs) 0;
  }
  .text-col {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-right: var(--space-3xl);
  }
  .heading,
  .body {
    margin: 0;
  }
  .media-col {
    flex: 1 0 0;
    min-width: 0;
  }
  .media-col :global(.media-frame) {
    width: 100%;
    border-radius: var(--radius-s);
  }
  @media (max-width: 768px) {
    .text-media {
      flex-direction: column;
      padding: var(--space-2xl) var(--space-3xs) 0;
    }
    .text-col {
      padding-right: 0;
    }
  }
</style>
