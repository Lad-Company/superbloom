---
import SurfaceSection from './SurfaceSection.astro';
import PageGrid from './PageGrid.astro';

type ContactSurfaceRole = 'brand-accent' | 'brand-deep' | 'brand-muted' | 'brand-tertiary';

interface Props {
  role: ContactSurfaceRole;
}

const { role } = Astro.props;
---

<SurfaceSection id="contact" role={role}>
  <section class="contact-band" aria-labelledby="contact-heading">
    <PageGrid class="contact-grid">
      <div class="page-grid-item contact-left">
        <h2 id="contact-heading" class="type-h5">Got a challenge that's too interesting for a normal agency?<br /><br />Let's talk.</h2>
      </div>
      <div class="page-grid-item contact-right">
        <form class="contact-form" id="contact-form" novalidate>
          <div class="fields">
            <div class="field-select">
              <select name="inquiryType" class="input input--filled" required>
                <option value="agency-partner">I am a brand looking for an agency partner</option>
                <option value="creator">I am a Creator</option>
                <option value="press">I am press / media</option>
                <option value="other">Other</option>
              </select>
              <span class="select-arrow" aria-hidden="true"></span>
            </div>
            <input class="input" type="text" name="name" placeholder="Name*" required />
            <input class="input" type="email" name="email" placeholder="Email*" required />
            <div class="field-select">
              <select name="hearAboutUs" class="input" required>
                <option value="" disabled selected>How did you hear about us?*</option>
                <option value="referral">Referral</option>
                <option value="instagram">Instagram</option>
                <option value="linkedin">LinkedIn</option>
                <option value="google">Google</option>
                <option value="event">Event</option>
                <option value="other">Other</option>
              </select>
              <span class="select-arrow" aria-hidden="true"></span>
            </div>
            <textarea class="input input--message" name="message" placeholder="Message*" rows="3" required></textarea>
          </div>
          <div class="contact-actions">
            <button class="btn-submit type-label" type="submit">Submit</button>
            <p class="status" id="contact-status" aria-live="polite"></p>
          </div>
        </form>
      </div>
    </PageGrid>
  </section>
</SurfaceSection>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-status');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    button.disabled = true;
    if (status) status.textContent = '';

    try {
      const response = await fetch('/api/contact', { method: 'POST', body: new FormData(form) });
      const data = await response.json() as { ok?: boolean; error?: string };
      if (!data.ok) throw new Error(data.error ?? 'Unknown error');
      form.reset();
      if (status) {
        status.textContent = "Thanks — we’ll be in touch.";
        status.classList.remove('status--error');
        status.classList.add('status--ok');
      }
    } catch {
      if (status) {
        status.textContent = 'Something went wrong. Please try again.';
        status.classList.add('status--error');
        status.classList.remove('status--ok');
      }
    } finally {
      button.disabled = false;
    }
  });
</script>

<style>
  .contact-band {
    padding-block: var(--space-4xl);
  }
  .contact-grid { align-items: start; }
  .contact-left {
    padding-right: var(--space-xl);
  }
  .type-h5 {
    margin: 0;
    font-family: var(--font-display-tight);
    font-size: 56px;
    font-weight: 750;
    line-height: 0.88;
    text-transform: uppercase;
  }
  .contact-form,
  .fields {
    display: flex;
    flex-direction: column;
  }
  .contact-form { gap: var(--space-xs); }
  .fields { gap: var(--space-3xs); }
  .input {
    box-sizing: border-box;
    width: 100%;
    height: 56px;
    padding: 0 var(--space-2xs);
    appearance: none;
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--fg) 30%, transparent);
    border-radius: var(--radius-input);
    color: var(--fg);
    font-family: var(--font-body);
    font-size: 19px;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }
  .input::placeholder { color: color-mix(in srgb, var(--fg) 50%, transparent); }
  .input:focus { outline: none; border-color: color-mix(in srgb, var(--fg) 60%, transparent); }
  .input--filled {
    background: var(--fg);
    border-color: color-mix(in srgb, var(--fg) 12%, transparent);
    color: var(--bg);
  }
  .input--message {
    height: auto;
    padding-top: 16px;
    padding-bottom: 16px;
    resize: vertical;
  }
  .field-select { position: relative; }
  .field-select select {
    cursor: pointer;
    padding-right: 40px;
  }
  .select-arrow {
    position: absolute;
    top: 50%;
    right: var(--space-2xs);
    width: 0;
    height: 0;
    pointer-events: none;
    transform: translateY(-50%);
    border-right: 4px solid transparent;
    border-bottom: 0;
    border-left: 4px solid transparent;
    border-top: 5px solid currentColor;
  }
  .input--filled + .select-arrow { color: var(--bg); }
  .contact-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
  }
  .btn-submit {
    padding: var(--space-3xs) 16px;
    border: none;
    border-radius: var(--radius-control);
    background: var(--fg);
    color: var(--bg);
    cursor: pointer;
    font-family: var(--font-interface);
    font-size: 17px;
    font-weight: 750;
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .btn-submit:disabled {
    cursor: default;
    opacity: 0.5;
  }
  .status {
    margin: 0;
    font-family: var(--font-body);
    font-size: 15px;
  }
  .status--ok { color: color-mix(in srgb, var(--fg) 70%, transparent); }
  .status--error { color: #ff6b6b; }

  @media (max-width: 1023px) {
    .contact-band { padding-block: var(--space-3xl); }
    .contact-left { padding-right: var(--space-2xs); }
    .type-h5 { font-size: clamp(40px, 6vw, 56px); }
  }
  @media (max-width: 767px) {
    .contact-band { padding-block: var(--space-2xl); }
    .contact-left { padding-right: 0; }
  }
</style>
