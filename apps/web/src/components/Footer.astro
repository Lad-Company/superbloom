---
import SurfaceSection from './SurfaceSection.astro';

const nav = [
  { label: 'Our Work', href: '/work' },
  { label: 'Who We Are', href: '/who-we-are' },
  { label: 'News & Press', href: '#' },
  { label: 'Zine', href: '#' },
  { label: 'Shop', href: '#' },
];
const social = ['Instagram', 'LinkedIn', 'Vimeo', 'YouTube'];
---

<SurfaceSection role="dark">
  <footer class="footer type-eyebrow">
    <div class="newsletter">
      <p class="type-h3 nl-heading">Subscribe to our newsletter</p>
      <form class="nl-form" onsubmit="return false">
        <input class="nl-input type-eyebrow" type="email" placeholder="Your email" aria-label="Email address" />
        <button class="nl-submit type-label" type="submit">Submit</button>
      </form>
    </div>
    <div class="cols">
      <div class="col contact">
        <a href="mailto:hello@superbloomhouse.com" class="email">hello@superbloomhouse.com</a>
        <p>
          <a href="https://maps.app.goo.gl/JQnEQbBXd1q9TAJu5" target="_blank" rel="noopener">
            5768 West Adams Blvd<br />Los Angeles, CA 90016
          </a><br />P - 310.913.5312
        </p>
        <p>
          NYC<br />
          <a href="https://goo.gl/maps/RvvdLkRkVatXafCi9" target="_blank" rel="noopener">
            77 10th Street, Floor 3<br />Brooklyn, NY 11215
          </a>
        </p>
      </div>
      <ul class="col">
        {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
      <ul class="col">
        {social.map((label) => <li><a href="#">{label}</a></li>)}
      </ul>
      <div class="col">
        <p>All content ©<br />Superbloomhouse 2026</p>
      </div>
    </div>
  </footer>
</SurfaceSection>

<style>
  .footer {
    padding: var(--space-4xl) var(--space-xs) var(--space-xs);
  }
  .newsletter {
    padding: 0 0 var(--space-2xl);
    border-bottom: 1px solid var(--fg-12);
    margin-bottom: var(--space-2xl);
  }
  .nl-heading {
    margin: 0 0 var(--space-xs);
    max-width: 10ch;
    text-transform: uppercase;
  }
  .nl-form {
    display: flex;
    gap: var(--page-gutter);
    align-items: center;
  }
  .nl-input {
    background: var(--fg-12);
    border: 1px solid var(--fg-12);
    border-radius: var(--radius-m);
    color: var(--fg);
    padding: var(--space-3xs) 16px;
    min-width: 280px;
  }
  .nl-input::placeholder {
    color: var(--fg-60);
  }
  .nl-submit {
    background: var(--fg);
    color: var(--bg);
    border: none;
    border-radius: var(--radius-s);
    padding: var(--space-3xs) 16px;
    cursor: pointer;
  }
  .cols {
    display: flex;
    gap: var(--page-gutter);
    align-items: flex-start;
  }
  .col {
    flex: 1 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
  .contact a {
    text-decoration: none;
  }
  .email {
    text-decoration: underline;
  }
  a {
    text-decoration: none;
  }
  p {
    margin: 0;
  }
  @media (max-width: 1023px) {
    .footer {
      padding: var(--space-3xl) var(--space-2xs) var(--space-2xs);
    }
    .cols {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      row-gap: var(--space-xl);
    }
  }
  @media (max-width: 767px) {
    .footer {
      padding: var(--space-2xl) var(--space-3xs) var(--space-3xs);
    }
    .newsletter {
      padding-bottom: var(--space-xl);
      margin-bottom: var(--space-xl);
    }
    .nl-form {
      align-items: stretch;
      flex-direction: column;
    }
    .nl-input {
      min-width: 0;
      width: 100%;
    }
    .cols {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>
