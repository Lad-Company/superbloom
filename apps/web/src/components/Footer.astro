---
const nav = [
  { label: 'Our Work', href: '/work' },
  { label: 'Who We Are', href: '/who-we-are' },
  { label: 'News & Press', href: '#' },
  { label: 'Zine', href: '#' },
  { label: 'Shop', href: '#' },
];
const social = ['Instagram', 'LinkedIn', 'Vimeo', 'YouTube'];
---

<footer class="footer type-eyebrow">
  <div class="newsletter">
    <p class="type-h3 nl-heading">Subscribe to our newsletter</p>
    <form class="nl-form" onsubmit="return false">
      <input class="nl-input type-eyebrow" type="email" placeholder="Your email" aria-label="Email address" />
      <button class="nl-submit type-label" type="submit">Submit</button>
    </form>
  </div>
  <div class="cols">
    <div class="col contact">
      <a href="mailto:hello@superbloomhouse.com" class="email">hello@superbloomhouse.com</a>
      <p>
        <a href="https://maps.app.goo.gl/JQnEQbBXd1q9TAJu5" target="_blank" rel="noopener">
          5768 West Adams Blvd<br />Los Angeles, CA 90016
        </a><br />P - 310.913.5312
      </p>
      <p>
        NYC<br />
        <a href="https://goo.gl/maps/RvvdLkRkVatXafCi9" target="_blank" rel="noopener">
          77 10th Street, Floor 3<br />Brooklyn, NY 11215
        </a>
      </p>
    </div>
    <ul class="col">
      {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
    </ul>
    <ul class="col">
      {social.map((label) => <li><a href="#">{label}</a></li>)}
    </ul>
    <div class="col">
      <p>All content ©<br />Superbloomhouse 2026</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--fg);
    color: var(--bg);
    padding: 0 var(--space-xs) var(--space-xs);
  }
  .newsletter {
    padding: var(--space-2xl) 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    margin-bottom: var(--space-2xl);
  }
  .nl-heading {
    margin: 0 0 var(--space-xs);
    max-width: 10ch;
    text-transform: uppercase;
  }
  .nl-form {
    display: flex;
    gap: var(--page-gutter);
    align-items: center;
  }
  .nl-input {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-m);
    color: var(--bg);
    padding: var(--space-3xs) 16px;
    min-width: 280px;
  }
  .nl-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }
  .nl-submit {
    background: var(--bg);
    color: var(--fg);
    border: none;
    border-radius: var(--radius-s);
    padding: var(--space-3xs) 16px;
    cursor: pointer;
  }
  .cols {
    display: flex;
    gap: var(--page-gutter);
    align-items: flex-start;
  }
  .col {
    flex: 1 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
  .contact a {
    text-decoration: none;
  }
  .email {
    text-decoration: underline;
  }
  a {
    text-decoration: none;
  }
  p {
    margin: 0;
  }
</style>
