---
import SurfaceSection from './SurfaceSection.astro';
import { sanityClient } from '../lib/sanity';
import { siteSettingsQuery } from '../lib/queries';
import type { SiteSettingsQueryResult } from '../sanity.types';

const nav = [
  { label: 'Our Work', href: '/work' },
  { label: 'Who We Are', href: '/who-we-are' },
  { label: 'News & Press', href: '/index' },
  { label: 'Zine', href: '/zine' },
  { label: 'Shop', href: '/shop' },
  { label: 'Edit', href: 'https://superbloom-cms.sanity.studio', external: true },
];
const siteSettings = await sanityClient.fetch<SiteSettingsQueryResult>(siteSettingsQuery);
const social = [
  { label: 'Instagram', href: siteSettings?.instagramUrl },
  { label: 'LinkedIn', href: siteSettings?.linkedInUrl },
  { label: 'Vimeo', href: siteSettings?.vimeoUrl },
  { label: 'YouTube', href: siteSettings?.youTubeUrl },
].filter((link): link is { label: string; href: string } => Boolean(link.href));
const currentYear = new Date().getFullYear();
---

<SurfaceSection role="dark" class="footer-surface">
  <footer class="footer type-eyebrow">
    <div class="newsletter">
      <p class="type-h3 nl-heading">Subscribe to The Microdose</p>
      <form class="nl-form" id="newsletter-form">
        <label class="sr-only" for="newsletter-email">Email address</label>
        <input class="nl-input type-body" id="newsletter-email" type="email" name="email" placeholder="Email" autocomplete="email" required />
        <input class="honeypot" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <input type="hidden" name="startedAt" />
        <button class="nl-submit surface-wipe type-label" type="submit" data-motion-control><span class="btn__label">Submit</span></button>
        <p class="nl-status" aria-live="polite" role="status"></p>
      </form>
    </div>
    <div class="cols">
      <div class="col contact">
        <a href="mailto:hello@superbloomhouse.com" class="email">hello@superbloomhouse.com</a>
        <p>
          <a href="https://maps.app.goo.gl/JQnEQbBXd1q9TAJu5" target="_blank" rel="noopener">
            5768 West Adams Blvd<br />Los Angeles, CA 90016
          </a><br />P - 310.913.5312
        </p>
        <p>
          NYC<br />
          <a href="https://goo.gl/maps/RvvdLkRkVatXafCi9" target="_blank" rel="noopener">
            77 10th Street, Floor 3<br />Brooklyn, NY 11215
          </a>
        </p>
      </div>
      <ul class="col">
        {nav.map((item) => (
          <li>
            <a href={item.href} class="underline-draw" target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener noreferrer' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      {social.length > 0 && (
        <ul class="col">
          {social.map((item) => (
            <li><a href={item.href} class="underline-draw" target="_blank" rel="noopener noreferrer">{item.label}</a></li>
          ))}
        </ul>
      )}
      <div class="col">
        <p>All content ©<br />Superbloom House {currentYear}</p>
      </div>
    </div>
  </footer>
</SurfaceSection>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const status = form?.querySelector('.nl-status');
  const startedAt = form?.elements.namedItem('startedAt') as HTMLInputElement | null;

  if (startedAt) startedAt.value = String(Date.now());

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form.reportValidity()) return;

    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    button.disabled = true;
    if (status) {
      status.textContent = 'Submitting…';
      status.className = 'nl-status';
    }

    try {
      const response = await fetch('/api/newsletter/subscribe.json', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await response.json() as {success?: boolean; error?: 'duplicate' | 'invalid' | 'network'};

      if (data.success) {
        form.reset();
        if (startedAt) startedAt.value = String(Date.now());
        if (status) {
          status.textContent = 'You’re subscribed.';
          status.classList.add('nl-status--ok');
        }
      } else if (status) {
        status.textContent = data.error === 'duplicate'
          ? 'You’re already subscribed.'
          : data.error === 'invalid'
            ? 'Enter a valid email address.'
            : 'Something went wrong. Please try again.';
        status.classList.add('nl-status--error');
      }
    } catch {
      if (status) {
        status.textContent = 'Something went wrong. Please try again.';
        status.className = 'nl-status nl-status--error';
      }
    } finally {
      button.disabled = false;
    }
  });
</script>

<style>
  .footer-surface {
    margin: 0 var(--space-xs) var(--space-xs);
    border-radius: 24px;
    overflow: hidden;
  }
  .footer {
    padding: var(--space-4xl) var(--space-xs) var(--space-xs);
  }
  .newsletter {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 1fr);
    gap: var(--page-gutter);
    align-items: start;
    padding: 0 0 var(--space-2xl);
    border-bottom: 1px solid var(--fg-12);
    margin-bottom: var(--space-2xl);
  }
  .nl-heading {
    margin: 0;
    max-width: 10ch;
    text-transform: uppercase;
  }
  .nl-form {
    display: flex;
    align-items: center;
    min-height: 56px;
    padding: var(--space-xs-4);
    border: 1px solid var(--fg-12);
    border-radius: var(--radius-input);
    position: relative;
  }
  .nl-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 0;
    color: var(--fg);
    padding: var(--space-3xs) 16px;
  }
  .nl-input::placeholder {
    color: var(--fg-60);
  }
  .nl-submit {
    background: var(--fg);
    color: var(--bg);
    border: none;
    border-radius: var(--radius-s);
    padding: var(--space-3xs) 16px;
    cursor: pointer;
    --wipe-surface: var(--bg);
    --wipe-ink: var(--fg);
  }
  .nl-submit:disabled {
    cursor: default;
    opacity: 0.5;
  }
  .nl-status {
    position: absolute;
    left: 0;
    top: calc(100% + var(--space-xs-4));
    margin: 0;
    font-family: var(--font-body);
    font-size: 15px;
  }
  .nl-status--ok { color: var(--fg-60); }
  .nl-status--error { color: #ff6b6b; }
  .honeypot,
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
  .cols {
    display: flex;
    gap: var(--page-gutter);
    align-items: flex-start;
  }
  .col {
    flex: 1 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
  .contact a {
    text-decoration: none;
  }
  .email {
    text-decoration: underline;
  }
  a {
    text-decoration: none;
  }
  p {
    margin: 0;
  }
  @media (max-width: 1023px) {
    .footer-surface {
      margin: 0 var(--space-2xs) var(--space-2xs);
    }
    .footer {
      padding: var(--space-3xl) var(--space-2xs) var(--space-2xs);
    }
    .newsletter {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }
    .cols {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      row-gap: var(--space-xl);
    }
  }
  @media (max-width: 767px) {
    .footer-surface {
      margin: 0 var(--space-3xs) var(--space-3xs);
      border-radius: 16px;
    }
    .footer {
      padding: var(--space-2xl) var(--space-3xs) var(--space-3xs);
    }
    .newsletter {
      padding-bottom: var(--space-xl);
      margin-bottom: var(--space-xl);
    }
    .nl-form {
      align-items: stretch;
    }
    .nl-input {
      min-width: 0;
      width: 100%;
    }
    .cols {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>
