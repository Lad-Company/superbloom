---
import EditorialCard from './EditorialCard.astro';
import TagList from './TagList.astro';
import type { Media } from './MediaFrame.astro';
import {
  type CardWidth,
  type InfoPosition,
  type MediaAspectRatio,
  type PartialContentCardSettings,
} from '../lib/contentCard';

interface Tag {
  title: string | null;
  color: string | null;
}

interface WorkItem {
  _id?: string | null;
  title: string | null;
  slug: string | null;
  summary: string | null;
  cardWidth?: CardWidth | null;
  mediaAspectRatio?: MediaAspectRatio | null;
  infoPosition?: InfoPosition | null;
  tags: Tag[] | null;
  media: Media | null;
}

interface Props {
  item: WorkItem;
  class?: string;
  settings?: PartialContentCardSettings;
  listSettings?: PartialContentCardSettings;
  globalSettings?: PartialContentCardSettings;
}

const { item, class: className, settings, listSettings, globalSettings } = Astro.props;
const href = item.slug ? `/work/${item.slug}` : '#';
---

<EditorialCard
  href={href}
  title={item.title}
  media={item.media}
  contentSettings={item}
  settings={settings}
  listSettings={listSettings}
  globalSettings={globalSettings}
  summary={item.summary}
  class={className}
  cardId={item._id}
>
  <TagList slot="overlay" tags={item.tags} />
</EditorialCard>
