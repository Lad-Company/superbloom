---
import EditorialCard from './EditorialCard.astro';
import TagList from './TagList.astro';
import type { Media, MediaRatio } from './MediaFrame.astro';

interface Tag {
  title: string | null;
  color: string | null;
}

interface WorkItem {
  title: string | null;
  slug: string | null;
  summary: string | null;
  cardAspectRatio: MediaRatio | null;
  tags: Tag[] | null;
  media: Media | null;
}

interface Props {
  item: WorkItem;
}

const { item } = Astro.props;
const href = item.slug ? `/work/${item.slug}` : '#';
---

<EditorialCard
  href={href}
  title={item.title}
  media={item.media}
  aspectRatio={item.cardAspectRatio}
  summary={item.summary}
>
  <TagList slot="overlay" tags={item.tags} />
</EditorialCard>
