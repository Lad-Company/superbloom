---
import ContentLayoutRow, {type ContentLayoutRowValue} from '../ContentLayoutRow.astro';

type Block = ContentLayoutRowValue;

interface Props {
  block: Block;
}

const {block} = Astro.props;
---

{block._type === 'contentLayoutRow' && (block.blocks?.length ?? 0) > 0 && (
  <div class="content-layout-row-shell">
    <ContentLayoutRow row={block} />
  </div>
)}

<style>
  .content-layout-row-shell {
    width: min(100% - (2 * var(--page-inset)), 1440px);
    margin: var(--space-xl) auto;
  }
</style>
