---
import Video from '../Video.astro';

interface Props {
  heading: string;
  subheading?: string | null;
  videoPlaybackId?: string | null;
}

const { heading, subheading, videoPlaybackId } = Astro.props;
---

<section class="hero">
  {
    videoPlaybackId && (
      <div class="bg">
        <Video playbackId={videoPlaybackId} title={heading} />
      </div>
    )
  }
  <div class="scrim"></div>
  <div class="overlay">
    <h1 class="type-h1">{heading}</h1>
    {subheading && <p class="type-caption sub">{subheading}</p>}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: clip;
    color: var(--bg);
  }
  .bg {
    position: absolute;
    inset: 0;
  }
  .bg :global(mux-player) {
    width: 100%;
    height: 100%;
    --controls: none;
    --media-object-fit: cover;
  }
  .scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35));
  }
  .overlay {
    position: absolute;
    inset: auto 0 0 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--page-gutter);
    align-items: end;
    padding: 80px var(--space-xs);
  }
  .overlay h1 {
    grid-column: 1 / 3;
    margin: 0;
    max-width: 15ch;
  }
  .sub {
    grid-column: 3;
    margin: 0;
    align-self: end;
  }
</style>
