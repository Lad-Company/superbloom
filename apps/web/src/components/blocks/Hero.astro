---
import MediaFrame, {type Media} from '../MediaFrame.astro';

interface Props {
  heading: string;
  subheading?: string | null;
  heroMedia?: Media | null;
}

const { heading, subheading, heroMedia } = Astro.props;
---

<section class="hero">
  <MediaFrame media={heroMedia} ratio="fill" title={heading} priority>
    <div class="scrim"></div>
    <div class="overlay">
      <h1 class="type-h1" data-motion-text data-unit="chars" data-blur data-scroll="false">{heading}</h1>
      {subheading && <p class="type-caption sub">{subheading}</p>}
    </div>
  </MediaFrame>
</section>

<style>
  .hero {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: clip;
    color: var(--bg);
  }

  .hero :global(media-frame) {
    position: absolute;
    inset: 0;
    border-radius: 0;
  }

  .scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35));
    pointer-events: none;
  }

  .overlay {
    position: absolute;
    inset: auto 0 0 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--page-gutter);
    align-items: end;
    padding: var(--space-xl) var(--page-inset);
    pointer-events: none;
  }

  .overlay h1 {
    grid-column: 1 / 3;
    margin: 0;
    max-width: 15ch;
  }

  .sub {
    grid-column: 3;
    margin: 0;
    align-self: end;
  }

  @media (max-width: 767px) {
    .hero {
      aspect-ratio: 375 / 667;
    }

    .overlay {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--space-3xs);
      padding: var(--space-3xs);
    }

    .overlay h1,
    .sub {
      grid-column: 1;
    }

    .overlay h1 {
      max-width: none;
      font-size: 72px;
    }
  }
</style>
