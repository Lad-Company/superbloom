---
import MediaFrame, {type Media} from '../MediaFrame.astro';

interface Props {
  heading: string;
  subheading?: string | null;
  heroMedia?: Media | null;
}

const { heading, subheading, heroMedia } = Astro.props;
---

<section class="hero">
  <MediaFrame media={heroMedia} ratio="fill" title={heading} priority>
    <div class="scrim"></div>
    <div class="overlay">
      <h1 class="type-h1">{heading}</h1>
      {subheading && <p class="type-caption sub">{subheading}</p>}
    </div>
  </MediaFrame>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: clip;
    color: var(--bg);
  }

  .hero :global(media-frame) {
    position: absolute;
    inset: 0;
    border-radius: 0;
  }

  .scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.35));
    pointer-events: none;
  }

  .overlay {
    position: absolute;
    inset: auto 0 0 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--page-gutter);
    align-items: end;
    padding: 80px var(--space-xs);
    pointer-events: none;
  }

  .overlay h1 {
    grid-column: 1 / 3;
    margin: 0;
    max-width: 15ch;
  }

  .sub {
    grid-column: 3;
    margin: 0;
    align-self: end;
  }
</style>
