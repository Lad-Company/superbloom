---
import SurfaceSection from '../SurfaceSection.astro';
import MediaFrame from '../MediaFrame.astro';
import PointerMediaGroup from '../PointerMediaGroup.astro';
import type { Media } from '../MediaFrame.astro';

interface Props {
  headline: string;
  body?: string | null;
  primaryMedia?: Media | null;
  secondaryMedia?: Media | null;
}

const { headline, body, primaryMedia, secondaryMedia } = Astro.props;
---

<SurfaceSection role="light">
  <div class="feature">
    <div class="text">
      <h2 class="type-h2" data-motion-text data-unit="words" data-scroll="true">{headline}</h2>
      {body && <p class="body type-body">{body}</p>}
    </div>
    <PointerMediaGroup class="visuals">
      {primaryMedia && (
        <div class="primary" data-pointer-depth="32">
          <MediaFrame media={primaryMedia} ratio="1:1" title={headline} />
        </div>
      )}
      {secondaryMedia && (
        <div class="secondary" data-pointer-depth="20">
          <MediaFrame media={secondaryMedia} ratio="3:2" title={headline} />
        </div>
      )}
    </PointerMediaGroup>
  </div>
</SurfaceSection>

<style>
  .feature {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(390px, 0.62fr);
    gap: var(--space-2xl);
    padding: var(--space-4xl) var(--page-inset) var(--space-3xl);
    align-items: start;
  }
  .text {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
  h2 {
    margin: 0;
  }
  .body {
    margin: 0;
    color: var(--fg-60);
    max-width: 40ch;
  }
  .visuals {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    align-items: start;
    min-height: min(50vw, 705px);
  }
  .primary {
    grid-column: 1 / -1;
    grid-row: 1;
    width: min(100%, 444px);
    justify-self: end;
  }
  .secondary {
    grid-column: 1;
    grid-row: 2;
    width: min(100%, 391px);
    margin-top: 0;
    align-self: end;
  }
  @media (max-width: 1023px) {
    .feature {
      grid-template-columns: 1fr;
      padding: var(--space-3xl) var(--space-2xs);
    }
    .visuals {
      min-height: 0;
      max-width: 680px;
      width: 100%;
      justify-self: end;
    }
  }
  @media (max-width: 767px) {
    .feature {
      padding: var(--space-2xl) var(--space-3xs);
      gap: var(--space-xl);
    }
    .visuals {
      grid-template-columns: 2fr 1.5fr;
      gap: var(--space-2xs);
    }
    .primary {
      grid-column: 1 / -1;
      width: 74%;
    }
    .secondary {
      grid-column: 1;
      width: 100%;
    }
  }
</style>
