---
interface Capability {
  title: string | null;
  slug: string | null;
  videoPlaybackId?: string | null;
}

interface Props {
  headline?: string | null;
  capabilities: Capability[];
}

const { headline, capabilities } = Astro.props;
---

<section class="capes" data-capes>
  <div class="pin" data-pin>
    <div class="media-stack">
      {
        capabilities.map((cap, i) => (
          <div class:list={['media', { 'is-active': i === 0 }]} data-media data-index={i}>
            {cap.videoPlaybackId ? (
              <mux-player
                playback-id={cap.videoPlaybackId}
                stream-type="on-demand"
                muted
                loop
                playsinline
                nohotkeys
                preload="auto"
              />
            ) : (
              <div class="media-placeholder" />
            )}
          </div>
        ))
      }
    </div>
    <div class="scrim"></div>
    <div class="overlay">
      {headline && <p class="headline type-h6">{headline}</p>}
      <ol class="list">
        {
          capabilities.map((cap, i) => (
            <li class:list={['type-h3', { 'is-active': i === 0 }]} data-cap data-index={i}>
              {cap.title}
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .capes {
    position: relative;
    background: var(--bg);
    color: var(--bg);
  }
  .pin {
    position: relative;
    height: 100vh;
    overflow: clip;
  }
  .media-stack {
    position: absolute;
    inset: 0;
  }
  .media {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .media.is-active {
    opacity: 1;
  }
  .media :global(mux-player) {
    width: 100%;
    height: 100%;
    --controls: none;
    --media-object-fit: cover;
  }
  .media-placeholder {
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.1);
  }
  .scrim {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.25);
  }
  .overlay {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--page-gutter);
    align-items: start;
    padding: var(--space-4xl) var(--space-xs) 0;
  }
  .headline {
    margin: 0;
    max-width: 24ch;
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .list li {
    color: var(--bg-60);
    transition: color 0.4s ease;
  }
  .list li.is-active {
    color: var(--bg);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import '@mux/mux-player';

  gsap.registerPlugin(ScrollTrigger);

  const sections = document.querySelectorAll<HTMLElement>('[data-capes]');

  sections.forEach((section) => {
    const items = section.querySelectorAll<HTMLElement>('[data-cap]');
    const medias = section.querySelectorAll<HTMLElement>('[data-media]');
    const pin = section.querySelector<HTMLElement>('[data-pin]');
    const count = items.length;
    if (!count || !pin) return;

    const setActive = (i: number) => {
      items.forEach((el, idx) => el.classList.toggle('is-active', idx === i));
      medias.forEach((el, idx) => {
        const active = idx === i;
        el.classList.toggle('is-active', active);
        const player = el.querySelector('mux-player') as HTMLVideoElement | null;
        if (!player) return;
        if (active) {
          void player.play?.()?.catch(() => {});
        } else {
          player.pause?.();
        }
      });
    };

    const mm = gsap.matchMedia();

    // Animated path: pin the visual and step the active capability as you scroll.
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      const st = ScrollTrigger.create({
        trigger: section,
        start: 'top top',
        end: `+=${count * 100}%`,
        pin,
        scrub: true,
        onUpdate: (self) => {
          const i = Math.min(count - 1, Math.floor(self.progress * count));
          setActive(i);
        },
      });
      return () => st.kill();
    });

    // Reduced motion: no pin/scrub; first capability stays active (static).
    setActive(0);
  });
</script>
