---
import MediaFrame, {type Media} from '../MediaFrame.astro';

interface Capability {
  title: string | null;
  subtitle?: string | null;
  slug: string | null;
  media?: Media | null;
}

interface Props {
  headline?: string | null;
  capabilities: Capability[];
}

const { headline, capabilities } = Astro.props;
const displayedCapabilities = capabilities.slice(0, 6);
---

<section class="capes" data-capes>
  <div class="pin" data-pin>
    <div class="media-stack">
      {
        displayedCapabilities.map((cap, i) => (
          <MediaFrame
            media={cap.media}
            ratio="fill"
            active={i === 0}
            class={`media-frame-item${i === 0 ? ' is-active' : ''}`}
          >
            <div class="scrim"></div>
            <div class="overlay">
              {headline && <p class="headline type-h6">{headline}</p>}
              <ol class="list">
                {
                  displayedCapabilities.map((c, idx) => (
                    <li class:list={['type-h3', { 'is-active': idx === i }]} data-cap data-index={idx}>
                      <span>{c.title}</span>
                      {c.subtitle && <span class="subtitle type-eyebrow">{c.subtitle}</span>}
                    </li>
                  ))
                }
              </ol>
            </div>
          </MediaFrame>
        ))
      }
    </div>
  </div>
</section>

<style>
  .capes {
    position: relative;
    background: var(--bg);
    color: var(--bg);
  }

  .pin {
    position: relative;
    height: 100vh;
    overflow: clip;
  }

  .media-stack {
    position: absolute;
    inset: 0;
  }

  .media-frame-item {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .media-frame-item.is-active {
    opacity: 1;
  }

  .scrim {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.25);
    pointer-events: none;
  }

  .overlay {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--page-gutter);
    align-items: start;
    padding: var(--space-4xl) var(--space-xs) 0;
    pointer-events: none;
  }

  .headline {
    margin: 0;
    max-width: 24ch;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .list li {
    display: flex;
    flex-direction: column;
    color: var(--bg-60);
    transition: color 0.4s ease;
  }

  .list li.is-active {
    color: var(--bg);
  }

  .subtitle {
    margin-top: var(--space-3xs);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const sections = document.querySelectorAll<HTMLElement>('[data-capes]');

  sections.forEach((section) => {
    const frames = section.querySelectorAll<HTMLElement>('media-frame');
    const pin = section.querySelector<HTMLElement>('[data-pin]');
    const count = frames.length;
    if (!count || !pin) return;

    const setActive = (i: number) => {
      frames.forEach((frame, idx) => {
        const isActive = idx === i;
        frame.toggleAttribute('active', isActive);
        frame.classList.toggle('is-active', isActive);
      });
    };

    const mm = gsap.matchMedia();

    mm.add('(prefers-reduced-motion: no-preference)', () => {
      const st = ScrollTrigger.create({
        trigger: section,
        start: 'top top',
        end: `+=${count * 100}%`,
        pin,
        scrub: true,
        onUpdate: (self) => {
          const i = Math.min(count - 1, Math.floor(self.progress * count));
          setActive(i);
        },
      });
      return () => st.kill();
    });

    setActive(0);
  });
</script>
