---
import MediaFrame, {type Media} from '../MediaFrame.astro';

interface Capability {
  title: string | null;
  contextualCopy?: string | null;
  slug: string | null;
  media?: Media | null;
}

interface Props {
  headline?: string | null;
  capabilities: Capability[];
}

const { headline, capabilities } = Astro.props;
const displayedCapabilities = capabilities.slice(0, 8);
---

<section class="capes" data-capes data-depth-scope>
  <div class="pin" data-pin>
    <div class="media-stack" data-depth="0.2">
      {
        displayedCapabilities.map((cap, i) => (
          <div class:list={['frame', { 'is-active': i === 0 }]} data-capes-frame>
            <MediaFrame media={cap.media} ratio="fill" active={i === 0}>
              <div class="scrim"></div>
            </MediaFrame>
          </div>
        ))
      }
    </div>
    <div class="overlay">
      <div class="context">
        {headline && <p class="headline type-h6">{headline}</p>}
        <div class="contextual-copy type-h6" aria-live="polite">
          {displayedCapabilities.map((cap, index) => (
            <p class:list={['copy', { 'is-active': index === 0 }]} data-context-copy data-index={index}>
              {cap.contextualCopy}
            </p>
          ))}
        </div>
      </div>
      <div class="list-clip">
        <ol class="list" data-capes-list>
          {
            displayedCapabilities.map((cap, index) => (
              <li class:list={['type-h3', { 'is-active': index === 0 }]} data-cap data-index={index}>
                {cap.title}
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </div>
</section>

<style>
  .capes {
    position: relative;
    background: var(--bg);
    color: var(--bg);
  }

  .pin {
    position: relative;
    height: 100vh;
  }

  .media-stack {
    position: absolute;
    inset: 0;
    overflow: clip;
  }

  .frame {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--motion-standard) var(--motion-ease-out);
  }

  .frame.is-active {
    opacity: 1;
  }

  .frame :global(.media-frame) {
    width: 100%;
    height: 100%;
  }

  .scrim {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.25);
    pointer-events: none;
  }

  .overlay {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--page-gutter);
    align-items: start;
    padding: var(--space-4xl) var(--space-xs) 0;
    pointer-events: none;
  }

  .context {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .headline {
    margin: 0;
    max-width: 24ch;
  }

  .contextual-copy {
    position: relative;
    min-height: 4.8em;
    max-width: 24ch;
  }

  .copy {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity var(--motion-standard) var(--motion-ease-out),
      transform var(--motion-standard) var(--motion-ease-out);
  }

  .copy.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  .list-clip {
    overflow: visible;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .list li {
    color: var(--bg-60);
    transition: color 0.4s ease;
  }

  .list li.is-active {
    color: var(--bg);
  }

  @media (max-width: 767px) {
    .overlay {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
      padding: var(--space-2xl) var(--space-3xs);
    }

    .list {
      gap: var(--space-3xs);
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { initDepthLayer, initPinnedStory } from '../../lib/motion';

  const cleanups: Array<() => void> = [];

  const initCapes = () => document.querySelectorAll<HTMLElement>('[data-capes]').forEach((section) => {
    if (section.dataset.capesInitialized) return;
    const frames = section.querySelectorAll<HTMLElement>('[data-capes-frame]');
    const listItems = section.querySelectorAll<HTMLElement>('[data-cap]');
    const contextualCopy = section.querySelectorAll<HTMLElement>('[data-context-copy]');
    const list = section.querySelector<HTMLElement>('[data-capes-list]');
    const listClip = list?.parentElement;
    const pin = section.querySelector<HTMLElement>('[data-pin]');
    const count = frames.length;
    if (!count || !pin) return;
    section.dataset.capesInitialized = 'true';

    const scrollListY = list ? gsap.quickTo(list, 'y', { duration: 0.55, ease: 'power2.out' }) : null;

    const setActive = (i: number) => {
      frames.forEach((frame, idx) => {
        const isActive = idx === i;
        frame.classList.toggle('is-active', isActive);
        frame.querySelector('media-frame')?.toggleAttribute('active', isActive);
      });
      listItems.forEach((item, idx) => item.classList.toggle('is-active', idx === i));
      contextualCopy.forEach((copy, idx) => copy.classList.toggle('is-active', idx === i));

      if (scrollListY && list && listClip) {
        const activeItem = listItems[i] as HTMLElement | undefined;
        if (activeItem) {
          const clipHeight = listClip.clientHeight;
          const itemOffset = activeItem.offsetTop;
          const itemHeight = activeItem.offsetHeight;
          const target = Math.max(0, itemOffset - (clipHeight / 2 - itemHeight / 2));
          scrollListY(-target);
        }
      }
    };

    const destroyPinnedStory = initPinnedStory({
      section,
      pin,
      chapters: count,
      onChapter: setActive,
      chapterScroll: 40,
    });
    const destroyDepthLayer = initDepthLayer(section);
    cleanups.push(() => {
      destroyPinnedStory();
      destroyDepthLayer();
      delete section.dataset.capesInitialized;
    });
  });

  initCapes();
  window.addEventListener('pagehide', () => cleanups.splice(0).forEach((cleanup) => cleanup()));
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) initCapes();
  });
</script>
