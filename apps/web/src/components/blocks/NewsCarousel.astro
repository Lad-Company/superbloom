---
import Section from '../case/Section.astro';
import CardCarousel from '../CardCarousel.astro';
import NewsCard from '../NewsCard.astro';
import type { HomepageQueryResult } from '../../sanity.types';

type NewsBlock = Extract<
  NonNullable<NonNullable<HomepageQueryResult>['sections']>[number],
  { _type: 'newsBlock' }
>;

interface Props {
  headline?: string | null;
  items: NewsBlock['items'];
}

const { headline, items } = Astro.props;
const [featured, ...rest] = items;
---

{
  items.length > 0 && (
    <Section theme="light" class="news">
      <div class="inner">
        {headline && <h2 class="type-h6 headline">{headline}</h2>}
        <CardCarousel label={headline ?? 'Latest news'}>
          {featured && <NewsCard item={featured} class="featured" showCopy />}
          {rest.map((item) => (
            <NewsCard item={item} class="standard" />
          ))}
        </CardCarousel>
      </div>
    </Section>
  )
}

<style>
  .inner {
    padding: var(--space-2xl) 0 var(--space-2xl) var(--space-xs);
  }
  .headline {
    margin: 0 0 var(--space-xs);
  }

  @media (max-width: 599px) {
    .inner {
      padding-left: 12px;
    }
  }
</style>
