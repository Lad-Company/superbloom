---
import CardCarousel from '../CardCarousel.astro';
import NewsCard from '../NewsCard.astro';
import SurfaceSection from '../SurfaceSection.astro';
import type { HomepageQueryResult } from '../../sanity.types';
import type {ContentCardSettingsInput, PartialContentCardSettings} from '../../lib/contentCard';

type NewsBlock = NonNullable<NonNullable<HomepageQueryResult>['news']>;

interface Props {
  headline?: string | null;
  items: NewsBlock['items'];
  role: 'light';
  listDefaults?: PartialContentCardSettings;
  itemOverrides?: Array<{articleId?: string | null} & ContentCardSettingsInput> | null;
  globalSettings?: PartialContentCardSettings;
}

const { headline, items: itemsInput, role, listDefaults: listSettings, itemOverrides, globalSettings } = Astro.props;
const items = itemsInput ?? [];
const overrides = new Map(itemOverrides?.map((override) => [override.articleId, override]));
---

{
  items.length > 0 && (
    <SurfaceSection role={role} class="news">
      <div class="inner">
        <CardCarousel class="news-carousel" label={headline ?? 'News'} heading={headline ?? 'News'}>
          {items.map((item) => (
            <NewsCard item={item} settings={overrides.get(item._id)} listSettings={listSettings} globalSettings={globalSettings} />
          ))}
        </CardCarousel>
      </div>
    </SurfaceSection>
  )
}

<style>
  .inner {
    padding: var(--space-2xl) var(--page-inset);
  }
  .headline {
    margin: 0 0 var(--space-xs);
  }

  @media (max-width: 599px) {
    .inner {
      padding-inline: 12px;
    }
  }
</style>
