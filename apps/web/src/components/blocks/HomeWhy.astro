---
import SurfaceSection from '../SurfaceSection.astro';
import MediaFrame from '../MediaFrame.astro';
import Button from '../Button.astro';
import type { Media } from '../MediaFrame.astro';

interface Props {
  headline: string;
  body?: string | null;
  ctaLabel?: string | null;
  ctaHref?: string | null;
  media?: Media | null;
}

const { headline, body, ctaLabel, ctaHref, media } = Astro.props;
---

<SurfaceSection role="light">
  <div class="why">
    <div class="text">
      <h2 class="type-h2" data-motion-text data-unit="words" data-scroll="true">{headline}</h2>
      {body && <p class="body type-body">{body}</p>}
      {ctaLabel && ctaHref && <Button href={ctaHref} label={ctaLabel} />}
    </div>
    {media && (
      <div class="visual">
        <MediaFrame {media} ratio="3:2" title={headline} />
      </div>
    )}
  </div>
</SurfaceSection>

<style>
  .why {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.72fr);
    gap: var(--page-gutter);
    padding: var(--space-4xl) var(--page-inset);
    align-items: start;
  }
  .text {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  h2 {
    margin: 0;
  }
  .body {
    margin: 0;
    max-width: 34ch;
  }
  .visual {
    padding-top: var(--space-xs);
  }
  @media (max-width: 1023px) {
    .why {
      grid-template-columns: 1fr;
      padding: var(--space-3xl) var(--space-2xs);
    }
  }
  @media (max-width: 767px) {
    .why {
      padding: var(--space-2xl) var(--space-3xs);
    }
  }
</style>
