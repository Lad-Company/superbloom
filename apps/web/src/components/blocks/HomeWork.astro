---
import SurfaceSection from '../SurfaceSection.astro';
import WorkCard from '../WorkCard.astro';
import Button from '../Button.astro';
import type { Media } from '../MediaFrame.astro';
import type { CardWidth, InfoPosition, MediaAspectRatio } from '../../lib/contentCard';

interface WorkItem {
  _id: string | null;
  title: string | null;
  slug: string | null;
  summary: string | null;
  cardWidth?: CardWidth | null;
  mediaAspectRatio?: MediaAspectRatio | null;
  infoPosition?: InfoPosition | null;
  tags: Array<{ title: string | null; color: string | null }> | null;
  media: Media | null;
}

interface Props {
  headline?: string | null;
  ctaLabel?: string | null;
  items: WorkItem[];
}

const { headline = 'Our Work', ctaLabel = 'View all', items } = Astro.props;
const displayedItems = items.slice(0, 4);
---

<SurfaceSection role="light">
  <div class="work">
    <div class="header">
      <h2 class="type-h2" data-motion-text data-unit="words" data-scroll="true">
        {headline}
      </h2>
      <Button href="/work" label={ctaLabel ?? 'View all'} outlineOnWipe />
    </div>
    {displayedItems.length > 0 && (
      <div class="grid">
        {displayedItems.map((item, index) => (
          <div class={`card card-${index + 1}`}>
            <WorkCard {item} />
          </div>
        ))}
      </div>
    )}
  </div>
</SurfaceSection>

<style>
  .work {
    padding: var(--space-4xl) var(--page-inset);
  }
  .header {
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    gap: var(--page-gutter);
    margin-bottom: var(--space-2xl);
  }
  h2 {
    margin: 0;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--space-l) var(--page-gutter);
    align-items: start;
  }
  .card-1 {
    grid-column: 1 / span 9;
  }
  .card-2 {
    grid-column: 10 / -1;
    padding-top: var(--space-xl);
  }
  .card-3 {
    grid-column: 4 / span 6;
    margin-top: calc(var(--space-xl) * -1);
  }
  .card-4 {
    grid-column: 7 / -1;
    margin-top: calc(var(--space-xl) * -1);
  }
  @media (max-width: 1023px) {
    .work {
      padding: var(--space-3xl) var(--space-2xs);
    }
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .card-1,
    .card-2,
    .card-3,
    .card-4 {
      grid-column: auto;
      margin-top: 0;
      padding-top: 0;
    }
  }
  @media (max-width: 767px) {
    .work {
      padding: var(--space-2xl) var(--space-3xs);
    }
    .header {
      align-items: flex-start;
    }
    .grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>
