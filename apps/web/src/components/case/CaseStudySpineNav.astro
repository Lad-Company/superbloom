---
import { caseStudySections } from '../../lib/caseStudySections';
---

<nav class="spine-nav type-label" aria-label="Case study sections">
  <ul>
    {caseStudySections.map((section, index) => (
      <li>
        <a
          href={`#${section.id}`}
          data-spine-link={section.id}
          aria-current={index === 0 ? 'location' : undefined}
        >
          {section.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  const links = [...document.querySelectorAll<HTMLAnchorElement>('[data-spine-link]')];
  const sections = links
    .map((link) => document.getElementById(link.dataset.spineLink ?? ''))
    .filter((section): section is HTMLElement => section !== null);
  let activeId = links.find((link) => link.hasAttribute('aria-current'))?.dataset.spineLink;

  const setActive = (id: string) => {
    if (id === activeId) return;
    activeId = id;
    links.forEach((link) => {
      if (link.dataset.spineLink === id) {
        link.setAttribute('aria-current', 'location');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  };

  const observer = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
      if (visible[0]?.target.id) setActive(visible[0].target.id);
    },
    { rootMargin: '-72px 0px -60% 0px', threshold: [0, 0.1] },
  );

  sections.forEach((section) => observer.observe(section));

  const clickHandlers = new Map<HTMLAnchorElement, (event: MouseEvent) => void>();
  links.forEach((link) => {
    const handleClick = (event: MouseEvent) => {
      const section = document.getElementById(link.dataset.spineLink ?? '');
      if (!section) return;
      event.preventDefault();
      section.scrollIntoView({
        behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
        block: 'start',
      });
      history.replaceState(null, '', link.hash);
      setActive(section.id);
    };
    clickHandlers.set(link, handleClick);
    link.addEventListener('click', handleClick);
  });

  const cleanup = () => {
    observer.disconnect();
    clickHandlers.forEach((handler, link) => link.removeEventListener('click', handler));
  };
  document.addEventListener('astro:before-swap', cleanup, { once: true });
</script>

<style>
  .spine-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    overflow-x: auto;
    background: var(--bg);
    color: var(--fg);
    scrollbar-width: none;
  }
  .spine-nav::-webkit-scrollbar {
    display: none;
  }
  ul {
    display: grid;
    grid-template-columns: repeat(5, minmax(max-content, 1fr));
    min-width: max-content;
  }
  a {
    display: block;
    padding: var(--space-2xs) 10px;
    border-bottom: 2px solid transparent;
    color: var(--fg-60);
    text-align: center;
    text-decoration: none;
  }
  a:hover,
  a:focus-visible,
  a[aria-current='location'] {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }
  a:focus-visible {
    outline: 2px solid var(--fg);
    outline-offset: -4px;
  }
  @media (max-width: 767px) {
    a {
      padding: 18px var(--space-3xs);
    }
  }
</style>
