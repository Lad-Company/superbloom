---
import Metric from '../Metric.astro';

interface Stat {
  _key: string;
  value: string | null;
  label: string | null;
}

interface Props {
  eyebrow?: string | null;
  stats?: Stat[] | null;
}

const { eyebrow, stats } = Astro.props;
---

<div class="outcomes">
  {eyebrow && <p class="type-eyebrow eyebrow">{eyebrow}</p>}
  {stats && stats.length > 0 && (
    <ul class="grid">
      {stats.map((stat) => (
        <li class="item">
          <Metric value={stat.value} label={stat.label} />
        </li>
      ))}
    </ul>
  )}
</div>

<style>
  .outcomes {
    padding: var(--space-2xl) var(--space-xs);
  }
  .eyebrow {
    margin: 0 0 var(--space-xs);
    color: var(--fg-60);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--page-gutter);
  }
  .item {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    padding-top: var(--space-xs);
    border-top: 1px solid var(--fg-12);
  }
  .item :global(.value) {
    display: block;
  }
  .item :global(.label) {
    display: block;
    opacity: 0.7;
  }
</style>
