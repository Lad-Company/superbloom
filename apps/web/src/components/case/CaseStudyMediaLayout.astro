---
import MediaFrame from '../MediaFrame.astro';
import PortableText from '../PortableText.astro';
import type { CaseStudyBySlugQueryResult } from '../../sanity.types';

type CaseStudy = NonNullable<CaseStudyBySlugQueryResult>;
type NarrativeSection = NonNullable<CaseStudy['highlights']>;
type MediaLayout = NonNullable<NarrativeSection['mediaLayouts']>[number];

interface Props {
  layout: MediaLayout;
  title?: string | null;
}

const { layout, title } = Astro.props;
---

{layout._type === 'caseStudyFullBleedMedia' && (
  <div class="full-bleed">
    <MediaFrame media={layout.media} ratio="16:9" title={title} />
  </div>
)}

{layout._type === 'caseStudyTextMedia' && (
  <div
    class:list={[
      'text-media',
      `media-${layout.mediaPosition}`,
      `width-${layout.mediaWidth ?? 'three-quarters'}`,
    ]}
  >
    <PortableText value={layout.text ?? []} class="text" />
    <MediaFrame media={layout.media} ratio="16:9" title={title} class="media" />
  </div>
)}

{layout._type === 'caseStudyPairedPortraitMedia' && (
  <div class="paired-portrait">
    {(layout.media ?? []).map((media) => (
      <MediaFrame media={media} ratio="4:5" title={title} />
    ))}
  </div>
)}

<style>
  .full-bleed,
  .text-media,
  .paired-portrait {
    min-width: 0;
  }
  .text-media {
    display: grid;
    gap: var(--page-gutter);
    align-items: start;
  }
  .width-half {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .width-three-quarters.media-right {
    grid-template-columns: minmax(240px, 1fr) minmax(0, 3fr);
  }
  .width-three-quarters.media-left {
    grid-template-columns: minmax(0, 3fr) minmax(240px, 1fr);
  }
  .media-left :global(.media) {
    order: -1;
  }
  .text {
    font-size: 17px;
  }
  .paired-portrait {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--page-gutter);
    max-width: 1028px;
    margin-left: auto;
  }
  @media (max-width: 1023px) {
    .text-media,
    .paired-portrait {
      grid-template-columns: 1fr;
    }
    .media-left :global(.media) {
      order: 0;
    }
    .paired-portrait {
      max-width: none;
      margin: 0;
    }
  }
</style>
