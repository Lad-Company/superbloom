---
import NewsCard from '../NewsCard.astro';
import ContentCardList from '../ContentCardList.astro';
import SurfaceSection from '../SurfaceSection.astro';
import type { CaseStudyBySlugQueryResult } from '../../sanity.types';
import type {PartialContentCardSettings} from '../../lib/contentCard';

type PressItem = NonNullable<NonNullable<CaseStudyBySlugQueryResult>['press']>[number];

interface Props {
  items: PressItem[];
  globalSettings?: PartialContentCardSettings;
}

const { items, globalSettings } = Astro.props;
const visibleItems = items.filter((item) => item?.slug).slice(0, 3);
---

{visibleItems.length > 0 && (
  <SurfaceSection role="light">
    <section class="press" aria-labelledby="case-study-press-heading">
      <h2 id="case-study-press-heading" class="type-h3">Press</h2>
      <ContentCardList class="grid">
        {visibleItems.map((item) => <NewsCard item={item} globalSettings={globalSettings} showCopy />)}
      </ContentCardList>
    </section>
  </SurfaceSection>
)}

<style>
  .press {
    padding: var(--space-4xl) var(--page-inset) var(--space-3xl);
  }
  h2 {
    margin: 0 0 var(--space-xl);
  }
  .grid {
    padding: 0;
  }
  @media (max-width: 1023px) {
    .press {
      padding-top: var(--space-3xl);
    }
  }
  @media (max-width: 767px) {
    .press {
      padding-block: var(--space-2xl);
    }
    h2 {
      font-size: 72px;
    }
  }
</style>
