---
import NarrativeBlockRenderer from '../narrative/NarrativeBlockRenderer.astro';
import NarrativeSectionNav from '../narrative/NarrativeSectionNav.astro';
import { blockId } from '../../lib/blockId';
import type { CaseStudyBySlugQueryResult } from '../../sanity.types';

type Block = NonNullable<NonNullable<CaseStudyBySlugQueryResult>['body']>[number];

interface Props {
  body?: Block[] | null;
}

const { body: rawBody } = Astro.props;
const body = rawBody ?? [];
const sectionNavItems = body
  .filter((block) => block.eyebrow)
  .map((block) => ({ label: block.eyebrow!, id: blockId(block.eyebrow!) }));
---

<NarrativeSectionNav items={[...sectionNavItems, { label: 'Press', id: 'press' }]} />

{body.map((block) => <NarrativeBlockRenderer block={block} />)}
