---
import SurfaceSection from '../SurfaceSection.astro';
import WorkCard from '../WorkCard.astro';
import ContentCardList from '../ContentCardList.astro';
import { fgForHex } from '../../lib/luminance';
import type { CaseStudyBySlugQueryResult } from '../../sanity.types';
import type {PartialContentCardSettings} from '../../lib/contentCard';

type NextProjectData = NonNullable<NonNullable<CaseStudyBySlugQueryResult>['nextProject']>;

interface Props {
  project: NextProjectData;
  globalSettings?: PartialContentCardSettings;
}

const { project, globalSettings } = Astro.props;
const background = project.primaryColor ?? '#ffffff';
const foreground = fgForHex(background);
const vars = `--case-primary-bg: ${background}; --case-primary-fg: ${foreground};`;
---

{project.slug && (
  <div style={vars}>
    <SurfaceSection role="case-primary">
      <section class="next-project" aria-labelledby="next-project-heading">
        <h2 id="next-project-heading" class="type-eyebrow">Next Project</h2>
        <ContentCardList>
          <WorkCard item={project} class="next-project-card" globalSettings={globalSettings} />
        </ContentCardList>
      </section>
    </SurfaceSection>
  </div>
)}

<style>
  .next-project {
    padding: var(--space-3xl) var(--page-inset);
  }
  h2 {
    margin: 0 0 var(--space-xl);
  }
  .next-project :global(.next-project-card .content) {
    gap: var(--space-3xs);
  }
  .next-project :global(.next-project-card .headline) {
    font-family: var(--font-display-tight);
    font-size: 120px;
    font-weight: 750;
    line-height: 0.88;
    text-transform: uppercase;
  }
  .next-project :global(.next-project-card .summary) {
    color: var(--fg);
  }
  @media (max-width: 1023px) {
    .next-project :global(.next-project-card .headline) {
      font-size: clamp(64px, 10vw, 100px);
    }
  }
  @media (max-width: 767px) {
    .next-project {
      padding-block: var(--space-2xl);
    }
  }
</style>
