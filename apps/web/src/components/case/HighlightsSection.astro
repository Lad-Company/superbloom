---
import PortableText from '../PortableText.astro';
import type { TypedObject } from 'astro-portabletext/types';

interface Stat {
  _key: string;
  value: string | null;
  label: string | null;
}

interface Props {
  eyebrow?: string | null;
  statement?: TypedObject[] | null;
  stats?: Stat[] | null;
}

const { eyebrow, statement, stats } = Astro.props;
---

<div class="highlights">
  <div class="inner">
    <div class="left">
      {eyebrow && <p class="type-eyebrow eyebrow">{eyebrow}</p>}
      {statement && statement.length > 0 && (
        <div class="statement type-h6">
          <PortableText value={statement} />
        </div>
      )}
    </div>
    {stats && stats.length > 0 && (
      <ul class="stats">
        {stats.map((s) => (
          <li class="stat type-eyebrow">
            {s.value && <span class="val">{s.value}</span>}
            {s.label && <span class="lbl">{s.label}</span>}
          </li>
        ))}
      </ul>
    )}
  </div>
</div>

<style>
  .highlights {
    padding: var(--space-2xl) var(--space-xs);
  }
  .inner {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-2xl) var(--page-gutter);
    align-items: start;
  }
  .eyebrow {
    margin: 0 0 var(--space-xs);
    color: var(--fg-60);
  }
  .statement {
    margin: 0;
  }
  .stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-top: calc(1em + var(--space-xs));
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: var(--space-xs);
    border-top: 1px solid var(--fg-12);
  }
  .val {
    display: block;
  }
  .lbl {
    display: block;
    color: var(--fg-60);
  }
</style>
