---
interface Tag {
  title?: string | null;
}

interface Props {
  tags?: Tag[] | null;
  typeLabel?: string;
  maxTags?: number;
}

const { tags = [], typeLabel, maxTags = 2 } = Astro.props;
const tagList = (tags ?? []).slice(0, maxTags);
---

{
  (typeLabel || tagList.length > 0) && (
    <ul class="tag-list">
      {typeLabel && <li class="tag type-label">{typeLabel}</li>}
      {tagList.map((tag) => (
        <li class="tag type-label">{tag.title}</li>
      ))}
    </ul>
  )
}

<style>
  .tag-list {
    position: absolute;
    inset: var(--space-3xs) auto auto var(--space-3xs);
    display: flex;
    gap: var(--space-xs-4);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tag {
    padding: 6px 10px;
    border: var(--border-subtle);
    border-radius: var(--radius-control);
    background: var(--frosted-layer);
    color: var(--bg);
    backdrop-filter: blur(var(--frosted-layer-blur));
    -webkit-backdrop-filter: blur(var(--frosted-layer-blur));
  }
</style>
