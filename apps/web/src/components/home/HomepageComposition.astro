---
import Hero from '../blocks/Hero.astro';
import Capes from '../blocks/Capes.astro';
import NewsCarousel from '../blocks/NewsCarousel.astro';
import ContactBand from '../ContactBand.astro';
import type { HomepageQueryResult } from '../../sanity.types';

type HomepageSection = NonNullable<NonNullable<HomepageQueryResult>['sections']>[number];

interface Props {
  sections: HomepageSection[];
}

const { sections } = Astro.props;

const moduleSurfaceRoles = {
  newsBlock: 'light',
  contactBlock: 'brand-deep',
} as const;
---

{
  sections.map((section) => {
    if (section._type === 'heroBlock') {
      return (
        <Hero
          heading={section.heading ?? ''}
          subheading={section.subheading}
          heroMedia={section.heroMedia}
        />
      );
    }

    if (section._type === 'capesBlock') {
      return <Capes headline={section.headline} capabilities={section.capabilities ?? []} />;
    }

    if (section._type === 'newsBlock') {
      return (
        <NewsCarousel
          headline={section.headline}
          items={section.items ?? []}
          role={moduleSurfaceRoles.newsBlock}
        />
      );
    }

    if (section._type === 'contactBlock') {
      return <ContactBand role={moduleSurfaceRoles.contactBlock} />;
    }

    return null;
  })
}
