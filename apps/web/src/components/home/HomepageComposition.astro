---
import Hero from '../blocks/Hero.astro';
import Capes from '../blocks/Capes.astro';
import NewsCarousel from '../blocks/NewsCarousel.astro';
import HomeFeature from '../blocks/HomeFeature.astro';
import HomeWork from '../blocks/HomeWork.astro';
import HomeWhy from '../blocks/HomeWhy.astro';
import HomeZine from '../blocks/HomeZine.astro';
import HomeTestimonials from '../blocks/HomeTestimonials.astro';
import ContactBand from '../ContactBand.astro';
import type { HomepageQueryResult } from '../../sanity.types';

interface Props {
  homepage: NonNullable<HomepageQueryResult>;
}

const { homepage } = Astro.props;

const moduleSurfaceRoles = {
  newsBlock: 'light',
  contactBlock: 'brand-deep',
} as const;
---

{homepage.hero && (
  <Hero
    heading={homepage.hero.heading ?? ''}
    subheading={homepage.hero.subheading}
    heroMedia={homepage.hero.heroMedia}
  />
)}

{homepage.news && (
  <NewsCarousel
    headline={homepage.news.headline}
    items={homepage.news.items ?? []}
    listDefaults={homepage.news.listDefaults}
    itemOverrides={homepage.news.itemOverrides}
    globalSettings={homepage.globalCardDefaults}
    role={moduleSurfaceRoles.newsBlock}
  />
)}

{homepage.feature && (
  <HomeFeature
    headline={homepage.feature.headline ?? ''}
    body={homepage.feature.body}
    media={homepage.feature.media}
  />
)}

{homepage.capabilities && (
  <Capes
    headline={homepage.capabilities.headline}
    capabilities={homepage.capabilities.capabilities ?? []}
  />
)}

{homepage.work && (
  <HomeWork
    headline={homepage.work.headline}
    ctaLabel={homepage.work.ctaLabel}
    items={homepage.work.items ?? []}
  />
)}

{homepage.why && (
  <HomeWhy
    headline={homepage.why.headline ?? ''}
    body={homepage.why.body}
    ctaLabel={homepage.why.ctaLabel}
    ctaHref={homepage.why.ctaHref}
    media={homepage.why.media}
  />
)}

{homepage.zine && (
  <HomeZine
    issue={homepage.zine.issue}
    currentIssueSlug={homepage.zine.currentIssueSlug}
    promoHeadline={homepage.zine.promoHeadline}
    promoIntro={homepage.zine.promoIntro}
    promoMedia={homepage.zine.promoMedia}
    ctaLabel={homepage.zine.ctaLabel}
  />
)}

{homepage.testimonials && (
  <HomeTestimonials
    headline={homepage.testimonials.headline}
    items={homepage.testimonials.items ?? []}
    ctaLabel={homepage.testimonials.ctaLabel}
    ctaHref={homepage.testimonials.ctaHref}
  />
)}

{homepage.contact && <ContactBand role={moduleSurfaceRoles.contactBlock} />}
