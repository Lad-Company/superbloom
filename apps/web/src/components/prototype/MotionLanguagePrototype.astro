---
const styles = {
  bloom: { label: 'Bloom', number: '01', color: '#99a224', inverse: '#111111', cadence: 'Elastic, human, bright' },
  editorial: { label: 'Editorial', number: '02', color: '#e6c6e2', inverse: '#111111', cadence: 'Precise, staged, typographic' },
  signal: { label: 'Signal', number: '03', color: '#3993dd', inverse: '#111111', cadence: 'Sharp, graphic, immediate' },
  cinema: { label: 'Cinema', number: '04', color: '#3f2293', inverse: '#ffffff', cadence: 'Slow, atmospheric, immersive' },
  signalCinema: { label: 'Signal / Cinema', number: '05', color: '#25205a', inverse: '#ffffff', cadence: 'Precise, immersive, responsive' },
} as const;

type Style = keyof typeof styles;
const requestedStyle = Astro.url.searchParams.get('variant') as Style;
const style: Style = requestedStyle in styles ? requestedStyle : 'bloom';
const current = styles[style];
---

<main class:list={['prototype', `style-${style}`]} style={`--accent:${current.color};--contrast:${current.inverse}`}>
  <div class="transition-curtain" aria-hidden="true"><span data-curtain-text>Work</span></div>

  <header class="site-nav" data-nav>
    <button class="wordmark" type="button" data-page="home">Superbloom<br />House</button>
    <nav aria-label="Prototype navigation">
      <button type="button" data-page="work">Work</button>
      <button type="button" data-page="about">Who we are</button>
      <button type="button" data-page="contact">Contact</button>
    </nav>
    <button class="menu-button" type="button" data-menu><span>Menu</span><i></i><i></i></button>
  </header>

  <aside class="menu-panel" data-menu-panel aria-hidden="true">
    <p>Navigate</p>
    <button type="button" data-page="work">Our work <span>↗</span></button>
    <button type="button" data-page="about">Who we are <span>↗</span></button>
    <button type="button" data-page="contact">Let's talk <span>↗</span></button>
  </aside>

  <aside class="case-panel" data-case-panel aria-hidden="true">
    <button class="case-close" type="button" data-case-close>Close <span>×</span></button>
    <p data-case-index>01 / Selected work</p>
    <h2 class="split-headline" data-case-title>Deel</h2>
    <div class="case-panel-media" data-case-media><i></i><i></i></div>
    <div class="case-panel-copy">
      <p data-case-description>Culture is currency. A global brand platform designed to move at the speed of work.</p>
      <button type="button" data-case-close>Back to work <span>↙</span></button>
    </div>
  </aside>

  <section class="page page-home is-active" data-page-view="home">
    <div class="hero">
      <div class="hero-meta reveal">Independent creative company<br />New York / Everywhere</div>
      <div class="hero-count reveal">01 — 04</div>
      <h1 class="split-headline" data-split>Make culture<br />move.</h1>
      <div class="hero-foot reveal">
        <p>We make brands impossible to ignore.</p>
        <div class="hero-actions">
          <button class="sound-button" type="button" data-sound aria-pressed="false"><i></i><span>Sound off</span></button>
          <button class="circle-link" type="button" data-page="work">Selected work <span>↓</span></button>
        </div>
      </div>
      <div class="hero-shape" aria-hidden="true"><i></i><i></i><i></i></div>
    </div>

    <section class="work-preview" data-reveal-section>
      <p class="section-label">Selected work <span>(01–03)</span></p>
      <div class="project-list">
        <button class="project" type="button" data-case="Deel"><span>01</span><strong>Deel</strong><em>Culture is currency</em><i></i></button>
        <button class="project" type="button" data-case="Tyson"><span>02</span><strong>Tyson</strong><em>We are what we eat</em><i></i></button>
        <button class="project" type="button" data-case="Silversea"><span>03</span><strong>Silversea</strong><em>The world awaits</em><i></i></button>
      </div>
    </section>

    <section class="loading-demo" data-reveal-section>
      <div>
        <p class="section-label">Loading state</p>
        <h2>Never leave<br />a blank beat.</h2>
      </div>
      <button class="load-control" type="button" data-load-control><span>Load next story</span><i>0%</i></button>
      <div class="load-preview" data-load-preview><span data-load-status>Preparing story</span><b></b><div class="load-skeleton"><i></i><i></i><i></i></div><strong data-load-title>Next: A world in motion</strong></div>
    </section>

    <section class="interaction-lab" data-reveal-section>
      <div><p class="section-label">Interaction states</p><h2>Every touch<br />has a response.</h2></div>
      <div class="interaction-controls">
        <button class="magnetic-button" type="button" data-magnetic>Get closer <span>→</span></button>
        <button class="pulse-button" type="button" data-pulse><i></i><span>Play the reel</span></button>
        <button class="text-button" type="button" data-toast>Save for later <span>+</span></button>
      </div>
      <div class="hover-compare" aria-label="Hover behavior comparison">
        <p>Hover directions</p>
        <button class="hover-shift" type="button">Shift / Invert <span>↗</span></button>
        <button class="hover-underline" type="button">Underline Draw <span>↗</span></button>
        <button class="hover-scale" type="button">Scale / Glow <span>↗</span></button>
        <button class="hover-wipe" type="button">Surface Wipe <span>↗</span></button>
      </div>
      <p class="interaction-toast" data-toast-message role="status">Saved to your moodboard</p>
    </section>

    <section class="scroll-sequence" data-scroll-sequence aria-label="Scroll motion study">
      <div class="sequence-intro"><p class="section-label">Scroll behavior</p><h2 class="split-headline" data-split>Keep<br />going.</h2><p>Scroll becomes a controlled camera move, giving each story a beginning, middle, and release.</p></div>
      <div class="sequence-track">
        <article class="sequence-panel panel-one"><p>01 / Establish</p><h3 class="scroll-word">Enter<br />the frame.</h3><i data-depth="0.15"></i></article>
        <article class="sequence-panel panel-two"><p>02 / Build</p><h3 class="scroll-word">Hold<br />the tension.</h3><i data-depth="0.3"></i></article>
        <article class="sequence-panel panel-three"><p>03 / Release</p><h3 class="scroll-word">Leave<br />a mark.</h3><i data-depth="0.48"></i></article>
      </div>
    </section>
  </section>

  <section class="page page-work" data-page-view="work">
    <div class="work-header">
      <p class="section-label">Work / selected</p>
      <h2 class="split-headline" data-split>Work people<br />want to watch.</h2>
      <p>Every project gets a tailored visual rhythm, governed by the same shared motion grammar.</p>
    </div>
    <div class="case-grid">
      <button class="case case-a" type="button" data-case="Deel"><span>01 / Film</span><strong>Deel</strong><i></i></button>
      <button class="case case-b" type="button" data-case="Tyson"><span>02 / Campaign</span><strong>Tyson</strong><i></i></button>
      <button class="case case-c" type="button" data-case="Silversea"><span>03 / Entertainment</span><strong>Silversea</strong><i></i></button>
    </div>
  </section>

  <section class="page page-about" data-page-view="about">
    <p class="section-label">The language</p>
    <h2 class="split-headline" data-split>One rhythm.<br />Every surface.</h2>
    <div class="principles">
      <article><span>01</span><h3>Arrive</h3><p>Every route enters with a legible sense of direction, never a generic fade.</p></article>
      <article><span>02</span><h3>Hold</h3><p>Type is treated as a living editorial material, paced in words and characters.</p></article>
      <article><span>03</span><h3>Release</h3><p>Hover, loading, scrolling and exit all inherit one consistent motion character.</p></article>
    </div>
  </section>

  <section class="page page-contact" data-page-view="contact">
    <p class="section-label">Start somewhere</p>
    <h2 class="split-headline" data-split>Let's make<br />something move.</h2>
    <form class="contact-form" data-contact-form>
      <label>What are you looking to move?<input name="brief" placeholder="A new brand platform, campaign, something else" /></label>
      <button class="contact-button" type="submit"><span data-contact-label>Start a conversation</span><span>↗</span></button>
    </form>
    <p class="contact-small">New business · hello@superbloom.house</p>
  </section>

  <div class="motion-console" data-console>
    <button type="button" data-replay aria-label="Replay this screen">↻</button>
    <span><b>{current.number}</b> {current.label}</span>
    <small>{current.cadence}</small>
  </div>

  <nav class="motion-style-switcher" aria-label="Motion style options">
    {Object.entries(styles).map(([key, value]) => (
      <a class:list={{ active: key === style }} href={`/prototype/motion?variant=${key}`}>{value.number} {value.label}</a>
    ))}
  </nav>
</main>

<script>
  import gsap from 'gsap';
  import Lenis from 'lenis';
  import SplitType from 'split-type';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const root = document.querySelector<HTMLElement>('.prototype');
  const curtain = document.querySelector<HTMLElement>('.transition-curtain');
  const curtainText = document.querySelector<HTMLElement>('[data-curtain-text]');
  const menu = document.querySelector<HTMLElement>('[data-menu-panel]');
  const menuButton = document.querySelector<HTMLButtonElement>('[data-menu]');
  const pages = [...document.querySelectorAll<HTMLElement>('[data-page-view]')];
  const casePanel = document.querySelector<HTMLElement>('[data-case-panel]');
  const caseTitle = document.querySelector<HTMLElement>('[data-case-title]');
  const caseIndex = document.querySelector<HTMLElement>('[data-case-index]');
  const caseDescription = document.querySelector<HTMLElement>('[data-case-description]');
  const caseData = {
    Deel: { index: '01 / Film', description: 'Culture is currency. A global brand platform designed to move at the speed of work.' },
    Tyson: { index: '02 / Campaign', description: 'A fresh visual language that turns everyday food into a cultural event.' },
    Silversea: { index: '03 / Entertainment', description: 'An invitation to make every horizon feel close enough to reach.' },
  };
  let activePage = 'home';
  let splits: SplitType[] = [];
  gsap.registerPlugin(ScrollTrigger);

  const setSplit = () => {
    splits.forEach((split) => split.revert());
    splits = [...document.querySelectorAll<HTMLElement>('[data-split]')].map((heading) =>
      new SplitType(heading, { types: 'lines,words,chars', tagName: 'span' }),
    );
  };

  const animateIn = (page: HTMLElement) => {
    setSplit();
    const timeline = gsap.timeline({ defaults: { ease: 'power4.out' } });
    const isSignal = root?.classList.contains('style-signal');
    const isCinema = root?.classList.contains('style-cinema');
    const isEditorial = root?.classList.contains('style-editorial');
    const isHybrid = root?.classList.contains('style-signalCinema');
    timeline.set(page, { autoAlpha: 1 });
    timeline.fromTo(page.querySelectorAll('.reveal, .section-label, .work-header > p, .contact-small'), { y: 18, autoAlpha: 0 }, { y: 0, autoAlpha: 1, duration: 0.5, stagger: 0.08 }, 0.15);
    timeline.fromTo(page.querySelectorAll('.char'), isHybrid ? { autoAlpha: 0, filter: 'blur(14px)', y: 42, rotate: -2 } : isCinema ? { autoAlpha: 0, filter: 'blur(16px)', y: 28 } : isSignal ? { x: -45, rotate: -8 } : isEditorial ? { yPercent: 115 } : { yPercent: 115, rotate: 4 }, isHybrid ? { autoAlpha: 1, filter: 'blur(0px)', y: 0, rotate: 0, duration: 0.72, stagger: 0.019, ease: 'power4.out' } : isCinema ? { autoAlpha: 1, filter: 'blur(0px)', y: 0, duration: 1.15, stagger: 0.035 } : isSignal ? { x: 0, rotate: 0, duration: 0.36, stagger: 0.012, ease: 'expo.out' } : { yPercent: 0, rotate: 0, duration: 0.75, stagger: isEditorial ? 0.008 : 0.018 }, 0.08);
    timeline.fromTo(page.querySelectorAll('.hero-shape i, .case, .principles article, .contact-button'), isSignal ? { xPercent: -18, autoAlpha: 0 } : isCinema || isHybrid ? { scale: 1.18, filter: 'blur(12px)', autoAlpha: 0 } : { scale: 0.78, autoAlpha: 0 }, isSignal ? { xPercent: 0, autoAlpha: 1, duration: 0.35, stagger: 0.07 } : isCinema || isHybrid ? { scale: 1, filter: 'blur(0px)', autoAlpha: 1, duration: isHybrid ? 0.75 : 1.1, stagger: isHybrid ? 0.1 : 0.16 } : { scale: 1, autoAlpha: 1, duration: 0.65, stagger: 0.1 }, 0.22);
    timeline.fromTo(page.querySelectorAll('.project'), { clipPath: 'inset(0 100% 0 0)' }, { clipPath: 'inset(0 0% 0 0)', duration: 0.55, stagger: 0.1 }, 0.28);
    return timeline;
  };

  const goToPage = (nextPage: string) => {
    const next = pages.find((page) => page.dataset.pageView === nextPage);
    const current = pages.find((page) => page.dataset.pageView === activePage);
    if (!next || !current || nextPage === activePage || !curtain || !curtainText) return;
    menu?.classList.remove('is-open');
    menuButton?.classList.remove('is-open');
    curtainText.textContent = nextPage === 'about' ? 'Us' : nextPage === 'contact' ? 'Hello' : nextPage === 'work' ? 'Work' : 'Home';
    const timeline = gsap.timeline();
    timeline.set(curtain, { autoAlpha: 1, yPercent: 100 });
    timeline.to(curtain, { yPercent: 0, duration: 0.68, ease: 'power4.inOut' });
    timeline.set(current, { autoAlpha: 0 });
    timeline.set(next, { autoAlpha: 1 });
    timeline.call(() => animateIn(next));
    timeline.to(curtain, { yPercent: -100, duration: 0.72, ease: 'power4.inOut' }, '+=0.18');
    activePage = nextPage;
  };

  document.querySelectorAll<HTMLElement>('[data-page]').forEach((trigger) => {
    trigger.addEventListener('click', () => goToPage(trigger.dataset.page ?? 'home'));
  });

  menuButton?.addEventListener('click', () => {
    menu?.classList.toggle('is-open');
    menuButton.classList.toggle('is-open');
  });

  document.querySelector<HTMLButtonElement>('[data-replay]')?.addEventListener('click', () => {
    const page = pages.find((candidate) => candidate.dataset.pageView === activePage);
    if (page) animateIn(page);
  });

  document.querySelectorAll<HTMLButtonElement>('[data-case]').forEach((project) => {
    project.addEventListener('click', () => {
      const name = project.dataset.case as keyof typeof caseData;
      const detail = caseData[name];
      if (!detail || !casePanel || !caseTitle || !caseIndex || !caseDescription) return;
      caseTitle.textContent = name;
      caseIndex.textContent = detail.index;
      caseDescription.textContent = detail.description;
      casePanel.classList.add('is-open');
      casePanel.setAttribute('aria-hidden', 'false');
      const split = new SplitType(caseTitle, { types: 'chars', tagName: 'span' });
      gsap.fromTo(casePanel.querySelectorAll('.char, .case-panel-copy, .case-panel-media'), { y: 30, autoAlpha: 0 }, { y: 0, autoAlpha: 1, duration: 0.6, stagger: 0.025, ease: 'power3.out' });
      window.setTimeout(() => split.revert(), 900);
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-case-close]').forEach((button) => {
    button.addEventListener('click', () => {
      if (!casePanel) return;
      gsap.to(casePanel, { autoAlpha: 0, duration: 0.25, onComplete: () => {
        casePanel.classList.remove('is-open');
        casePanel.removeAttribute('style');
        casePanel.setAttribute('aria-hidden', 'true');
      } });
    });
  });

  document.querySelector<HTMLButtonElement>('[data-load-control]')?.addEventListener('click', (event) => {
    const control = event.currentTarget;
    const preview = document.querySelector<HTMLElement>('[data-load-preview]');
    const status = document.querySelector<HTMLElement>('[data-load-status]');
    const title = document.querySelector<HTMLElement>('[data-load-title]');
    if (!preview || control.dataset.loading) return;
    control.dataset.loading = 'true';
    const value = control.querySelector('i');
    status && (status.textContent = 'Buffering film');
    title && (title.textContent = 'Finding the next story');
    gsap.timeline({
      onComplete: () => {
        delete control.dataset.loading;
        if (value) value.textContent = 'Loaded';
        status && (status.textContent = 'Ready to play');
        title && (title.textContent = 'Next: The world is waiting');
      },
    })
      .set(preview, { className: '+=is-loading' })
      .to({ progress: 0 }, { progress: 100, duration: 1.2, ease: 'power2.inOut', onUpdate() { if (value) value.textContent = `${Math.round(this.targets()[0].progress)}%`; } })
      .to(preview, { scale: 1.03, duration: 0.18, yoyo: true, repeat: 1 })
      .set(preview, { className: '+=is-loaded' });
  });

  document.querySelector<HTMLFormElement>('[data-contact-form]')?.addEventListener('submit', (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const label = form.querySelector<HTMLElement>('[data-contact-label]');
    const input = form.querySelector<HTMLInputElement>('input');
    if (!label || !input) return;
    gsap.to(input, { x: 8, duration: 0.08, yoyo: true, repeat: 3 });
    label.textContent = 'Message received';
    form.classList.add('is-sent');
  });

  document.querySelector<HTMLButtonElement>('[data-sound]')?.addEventListener('click', (event) => {
    const button = event.currentTarget;
    const isActive = button.getAttribute('aria-pressed') === 'true';
    button.setAttribute('aria-pressed', String(!isActive));
    button.querySelector('span')!.textContent = isActive ? 'Sound off' : 'Sound on';
  });

  document.querySelector<HTMLButtonElement>('[data-pulse]')?.addEventListener('click', (event) => {
    const button = event.currentTarget;
    button.classList.toggle('is-playing');
    button.querySelector('span')!.textContent = button.classList.contains('is-playing') ? 'Pause the reel' : 'Play the reel';
  });

  document.querySelector<HTMLButtonElement>('[data-toast]')?.addEventListener('click', () => {
    const toast = document.querySelector<HTMLElement>('[data-toast-message]');
    if (!toast) return;
    gsap.killTweensOf(toast);
    gsap.fromTo(toast, { y: 18, autoAlpha: 0 }, { y: 0, autoAlpha: 1, duration: 0.35, ease: 'power3.out', onComplete: () => gsap.to(toast, { autoAlpha: 0, delay: 2.2, duration: 0.35 }) });
  });

  document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((button) => {
    button.addEventListener('pointermove', (event) => {
      const bounds = button.getBoundingClientRect();
      gsap.to(button, { x: (event.clientX - bounds.left - bounds.width / 2) * 0.18, y: (event.clientY - bounds.top - bounds.height / 2) * 0.18, duration: 0.25, ease: 'power3.out' });
    });
    button.addEventListener('pointerleave', () => gsap.to(button, { x: 0, y: 0, duration: 0.6, ease: 'elastic.out(1, .4)' }));
  });

  if (root?.classList.contains('style-signal') || root?.classList.contains('style-cinema') || root?.classList.contains('style-signalCinema')) {
    const isCinematicScroll = root.classList.contains('style-cinema') || root.classList.contains('style-signalCinema');
    const lenis = new Lenis({ lerp: isCinematicScroll ? 0.075 : 0.12, smoothWheel: true });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => lenis.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);

    const sequence = document.querySelector<HTMLElement>('[data-scroll-sequence]');
    const panels = gsap.utils.toArray<HTMLElement>('.sequence-panel');
    if (sequence && panels.length) {
      const scrollTimeline = gsap.timeline({
        scrollTrigger: {
          trigger: sequence,
          start: 'top top',
          end: '+=300%',
          scrub: isCinematicScroll ? 1.15 : 0.5,
          pin: true,
          anticipatePin: 1,
        },
      });
      scrollTimeline.fromTo(panels, { xPercent: (index) => index * 105, autoAlpha: (index) => index === 0 ? 1 : 0 }, { xPercent: (index) => index === 0 ? -18 : (index - 1) * 4, autoAlpha: 1, duration: 3, stagger: 0.9, ease: 'none' });
      panels.forEach((panel) => {
        const split = new SplitType(panel.querySelector<HTMLElement>('.scroll-word')!, { types: 'chars', tagName: 'span' });
        gsap.fromTo(split.chars, { yPercent: 120, filter: isCinematicScroll ? 'blur(12px)' : 'blur(0px)', rotate: root.classList.contains('style-signal') ? -10 : 0, autoAlpha: 0 }, { yPercent: 0, filter: 'blur(0px)', rotate: 0, autoAlpha: 1, stagger: 0.02, ease: 'power3.out', scrollTrigger: { trigger: panel, containerAnimation: scrollTimeline, start: 'left 70%', toggleActions: 'play none none reverse' } });
        gsap.to(panel.querySelector('[data-depth]'), { yPercent: -45, rotation: root.classList.contains('style-signal') ? 30 : -12, ease: 'none', scrollTrigger: { trigger: panel, containerAnimation: scrollTimeline, start: 'left right', end: 'right left', scrub: true } });
      });
    }

    gsap.to('.hero-shape', { yPercent: isCinematicScroll ? 18 : -15, rotation: root.classList.contains('style-signal') ? 18 : -8, ease: 'none', scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: true } });
    gsap.to('.hero-meta', { yPercent: -60, autoAlpha: 0, ease: 'none', scrollTrigger: { trigger: '.hero', start: '20% top', end: 'bottom top', scrub: true } });
  }

  document.addEventListener('keydown', (event) => {
    if (event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    const styleLinks = [...document.querySelectorAll<HTMLAnchorElement>('.motion-style-switcher a')];
    const selected = styleLinks.findIndex((link) => link.classList.contains('active'));
    if (event.key === 'ArrowRight' || event.key === 'ArrowLeft') {
      event.preventDefault();
      const direction = event.key === 'ArrowRight' ? 1 : -1;
      styleLinks[(selected + direction + styleLinks.length) % styleLinks.length]?.click();
    }
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) gsap.fromTo(entry.target.querySelectorAll('.project, .loading-demo > *'), { y: 32, autoAlpha: 0 }, { y: 0, autoAlpha: 1, stagger: 0.12, duration: 0.65, ease: 'power3.out' });
    });
  }, { threshold: 0.25 });
  document.querySelectorAll<HTMLElement>('[data-reveal-section]').forEach((section) => observer.observe(section));

  animateIn(pages[0]);
</script>

<style>
  .prototype { --ink: #090909; min-height: 100vh; overflow: hidden; color: var(--ink); background: var(--accent); }
  button { font: inherit; color: inherit; cursor: pointer; } .site-nav { position: fixed; z-index: 20; inset: 0 0 auto; display: flex; align-items: flex-start; justify-content: space-between; padding: 26px 30px; mix-blend-mode: normal; }
  .wordmark { border: 0; padding: 0; background: none; font: 500 18px/.82 var(--font-display-tight); text-align: left; letter-spacing: -.03em; } .site-nav nav { display: flex; gap: 28px; } .site-nav nav button, .menu-button { border: 0; padding: 0; background: none; font: 500 13px var(--font-body); }
  .menu-button { display: flex; gap: 5px; align-items: center; } .menu-button i { width: 17px; border-top: 1px solid; transition: transform .35s ease; } .menu-button i + i { margin-left: -22px; transform: translateY(4px); } .menu-button.is-open i:first-of-type { transform: rotate(45deg) translate(2px, 2px); } .menu-button.is-open i + i { transform: rotate(-45deg) translate(-1px, 1px); }
  .menu-panel { position: fixed; z-index: 18; inset: 0; display: flex; flex-direction: column; justify-content: end; gap: 7px; padding: 120px 30px 35px; background: var(--ink); color: var(--accent); clip-path: inset(0 0 100% 0); transition: clip-path .7s cubic-bezier(.77, 0, .18, 1); } .menu-panel.is-open { clip-path: inset(0); } .menu-panel p { margin: auto 0 12px; font: 12px var(--font-body); text-transform: uppercase; } .menu-panel button { display: flex; justify-content: space-between; border: 0; padding: 0; background: none; font: 400 clamp(48px, 8vw, 110px)/.84 var(--font-display-tight); letter-spacing: -.07em; text-align: left; }
  .page { position: absolute; inset: 0; visibility: hidden; min-height: 100vh; opacity: 0; pointer-events: none; } .page.is-active { position: relative; visibility: visible; opacity: 1; pointer-events: auto; }
