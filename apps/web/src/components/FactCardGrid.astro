---
import Metric from './Metric.astro';
import SurfaceSection from './SurfaceSection.astro';

interface FactCard {
  _key?: string;
  label: string | null;
  value?: string | null;
  description?: string | null;
  items?: string[] | null;
}

interface Props {
  cards: FactCard[];
}

const { cards } = Astro.props;
const surfaceRoles = ['brand-muted', 'brand-deep', 'brand-accent'] as const;
---

<div class="fact-card-grid" data-fact-card-grid>
  {cards.map((card, index) => {
    const role = surfaceRoles[index % surfaceRoles.length];

    return (
      <SurfaceSection role={role} class="fact-card">
        <h2 class="label type-h5">{card.label}</h2>
        <div class="body">
          {card.value && <Metric value={card.value} />}
          {card.description && <p class="description type-caption">{card.description}</p>}
          {card.items && card.items.length > 0 && (
            <ul class="items type-h6">
              {card.items.map((item) => <li>{item}</li>)}
            </ul>
          )}
        </div>
      </SurfaceSection>
    );
  })}
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { EASE, MOTION, STAGGER, prefersReducedMotion } from '../lib/motion/config';

  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('[data-fact-card-grid]').forEach((grid) => {
    if (prefersReducedMotion()) return;

    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.fact-card'));

    gsap.fromTo(
      cards,
      { autoAlpha: 0, y: 40 },
      {
        autoAlpha: 1,
        y: 0,
        duration: MOTION.standard,
        stagger: STAGGER.standard,
        ease: EASE.out,
        scrollTrigger: {
          trigger: grid,
          start: 'top 80%',
          once: true,
        },
      }
    );

    cards.forEach((card) => {
      const valueEl = card.querySelector<HTMLElement>('.value');
      if (!valueEl) return;

      const raw = valueEl.textContent?.trim() ?? '';
      const match = raw.match(/^(\d+(?:\.\d+)?)(.*)$/);
      if (!match) return;

      const target = parseFloat(match[1]);
      const suffix = match[2] ?? '';
      const counter = { val: 0 };

      gsap.to(counter, {
        val: target,
        duration: MOTION.chapter,
        ease: EASE.out,
        onUpdate() {
          valueEl.textContent = `${Math.round(counter.val)}${suffix}`;
        },
        scrollTrigger: {
          trigger: card,
          start: 'top 80%',
          once: true,
        },
      });
    });
  });
</script>

<style>
  .fact-card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  :global(.fact-card) {
    display: flex;
    min-width: 0;
    min-height: 600px;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-xs);
  }

  :global(.fact-card .label),
  :global(.fact-card .description) {
    margin: 0;
  }

  :global(.fact-card .body) {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  :global(.fact-card .description) {
    max-width: 24ch;
  }

  :global(.fact-card .items) {
    line-height: 1.2;
  }

  :global(.fact-card .items li) {
    margin: 0;
  }

  :global(.fact-card .body .value) {
    display: block;
    font-size: clamp(80px, 9.7vw, 140px);
  }

  @media (max-width: 768px) {
    .fact-card-grid {
      grid-template-columns: 1fr;
    }

    :global(.fact-card) {
      min-height: 320px;
      padding: var(--space-3xs);
    }
  }
</style>
