---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="marquee-track" aria-hidden="true">
  <p class="marquee-text">{text}&nbsp;&nbsp;{text}&nbsp;&nbsp;{text}</p>
</div>

<style>
  .marquee-track {
    overflow: hidden;
    padding: var(--space-2xl) 0;
  }
  .marquee-text {
    margin: 0;
    font-family: var(--font-marquee);
    font-weight: 750;
    font-size: clamp(80px, 13vw, 200px);
    line-height: 0.78;
    text-transform: uppercase;
    color: var(--fg);
    white-space: nowrap;
  }
</style>
