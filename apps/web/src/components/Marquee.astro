---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="marquee-track" aria-hidden="true" data-marquee>
  <p class="marquee-text" data-marquee-text>{text}&nbsp;&nbsp;{text}&nbsp;&nbsp;{text}</p>
</div>

<script>
  import { initScrollDrivenTrack } from '../lib/motion';

  const cleanups: Array<() => void> = [];

  const initMarquees = () => document.querySelectorAll<HTMLElement>('[data-marquee]').forEach((track) => {
    if (track.dataset.marqueeInitialized) return;
    const text = track.querySelector<HTMLElement>('[data-marquee-text]');
    if (!text) return;
    track.dataset.marqueeInitialized = 'true';

    const scrollDrivenTrack = initScrollDrivenTrack({
      trigger: track,
      viewport: track,
      track: text,
      getX: () => -text.scrollWidth / 3,
      end: '+=100%',
    });

    cleanups.push(() => {
      scrollDrivenTrack.destroy();
      delete track.dataset.marqueeInitialized;
    });
  });

  initMarquees();
  window.addEventListener('pagehide', () => cleanups.splice(0).forEach((cleanup) => cleanup()));
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) initMarquees();
  });
</script>

<style>
  .marquee-track {
    overflow: hidden;
    padding: var(--space-2xl) 0;
  }
  .marquee-text {
    margin: 0;
    font-family: var(--font-marquee);
    font-weight: 750;
    font-size: clamp(80px, 13vw, 200px);
    line-height: 0.78;
    text-transform: uppercase;
    color: var(--fg);
    white-space: nowrap;
    will-change: transform;
  }
</style>
