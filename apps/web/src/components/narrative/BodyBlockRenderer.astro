---
import SurfaceSection from '../SurfaceSection.astro';
import HighlightsSection from '../case/HighlightsSection.astro';
import TextSection from '../case/TextSection.astro';
import MediaSection from '../case/MediaSection.astro';
import Outcomes from '../case/Outcomes.astro';
import { blockId } from '../../lib/blockId';
import type { CaseStudyBySlugQueryResult, NewsBySlugQueryResult } from '../../sanity.types';

type CaseBlock = NonNullable<NonNullable<CaseStudyBySlugQueryResult>['body']>[number];
type NewsBlock = NonNullable<NonNullable<NewsBySlugQueryResult>['body']>[number];
type Block = CaseBlock | NewsBlock;

interface Props {
  block: Block;
}

const { block } = Astro.props;
const id = block.eyebrow ? blockId(block.eyebrow) : undefined;
const role = block.theme ?? 'light';
---

{block._type === 'highlightsSection' && (
  <SurfaceSection role={role} id={id}>
    <HighlightsSection
      eyebrow={block.eyebrow}
      statement={block.statement ?? undefined}
      stats={block.stats ?? undefined}
    />
  </SurfaceSection>
)}

{block._type === 'textSection' && (
  <SurfaceSection role={role} id={id}>
    <TextSection eyebrow={block.eyebrow} body={block.body ?? undefined} />
  </SurfaceSection>
)}

{block._type === 'mediaSection' && (
  <SurfaceSection role={role} id={id}>
    <MediaSection layout={block.layout} media={block.media ?? undefined} text={block.text ?? undefined} />
  </SurfaceSection>
)}

{block._type === 'statsSection' && (
  <SurfaceSection role={role} id={id}>
    <Outcomes eyebrow={block.eyebrow} stats={block.stats ?? undefined} />
  </SurfaceSection>
)}
