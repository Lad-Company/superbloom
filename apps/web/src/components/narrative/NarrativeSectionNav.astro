---
interface Item {
  id: string;
  label: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<nav class="section-nav type-eyebrow" aria-label="Case study sections">
  <ul class="section-nav-list">
    {items.map((item) => (
      <li>
        <a href={`#${item.id}`} class="section-nav-link">{item.label}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .section-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    background: var(--bg);
    border-bottom: 1px solid var(--fg-12);
  }
  .section-nav-list {
    display: flex;
    gap: 0;
    padding: 0 var(--space-xs);
  }
  .section-nav-link {
    display: block;
    padding: var(--space-3xs) var(--space-2xs);
    text-decoration: none;
    color: var(--fg-60);
    border-bottom: 2px solid transparent;
  }
  .section-nav-link:hover,
  .section-nav-link:focus-visible {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }
</style>
