---
interface FaqItem {
  _key?: string;
  question: string | null;
  answer?: string | null;
}

interface Props {
  heading?: string;
  items: FaqItem[];
}

const { heading = 'FAQ', items } = Astro.props;
---

<div class="faq">
  <p class="faq-heading type-h4">{heading}</p>
  <ul class="faq-list">
    {items.map((item) => (
      <li>
        <details class="faq-item" data-faq-item>
          <summary class="faq-question">
            <span class="question-text type-h6">{item.question}</span>
            <span class="icon" aria-hidden="true">+</span>
          </summary>
          {item.answer && (
            <div class="faq-body" data-faq-body>
              <p class="faq-answer type-caption">{item.answer}</p>
            </div>
          )}
        </details>
      </li>
    ))}
  </ul>
</div>

<script>
  import gsap from 'gsap';
  import { EASE, MOTION, prefersReducedMotion } from '../lib/motion/config';

  if (!prefersReducedMotion()) {
    document.querySelectorAll<HTMLDetailsElement>('[data-faq-item]').forEach((details) => {
      const summary = details.querySelector<HTMLElement>('.faq-question');
      const body = details.querySelector<HTMLElement>('[data-faq-body]');
      const icon = details.querySelector<HTMLElement>('.icon');
      if (!summary || !body) return;

      // Keep body hidden until opened; GSAP manages the height.
      gsap.set(body, { height: 0, overflow: 'hidden' });

      summary.addEventListener('click', (e) => {
        e.preventDefault();

        if (!details.open) {
          details.open = true;
          gsap.to(body, { height: 'auto', duration: MOTION.standard, ease: EASE.out });
          if (icon) gsap.to(icon, { rotation: 45, duration: MOTION.quick, ease: EASE.out });
        } else {
          gsap.to(body, {
            height: 0,
            duration: MOTION.standard,
            ease: EASE.out,
            onComplete: () => { details.open = false; },
          });
          if (icon) gsap.to(icon, { rotation: 0, duration: MOTION.quick, ease: EASE.out });
        }
      });
    });
  }
</script>

<style>
  .faq {
    display: flex;
    gap: var(--page-gutter);
    align-items: flex-start;
    padding: var(--space-4xl) var(--space-xs) var(--space-3xl);
  }
  .faq-heading {
    flex: 1 0 0;
    min-width: 0;
    margin: 0;
    padding-right: var(--space-xl);
  }
  .faq-list {
    flex: 0 0 auto;
    width: 50%;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .faq-item {
    border-top: 1px solid var(--fg-12);
  }
  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs);
    padding: var(--space-xs) 0;
    cursor: pointer;
    list-style: none;
  }
  .faq-question::-webkit-details-marker {
    display: none;
  }
  .question-text {
    flex: 1 0 0;
    min-width: 0;
  }
  .icon {
    font-size: 24px;
    line-height: 1;
    flex-shrink: 0;
    font-family: var(--font-body);
    font-weight: 400;
    display: inline-block;
  }
  .faq-body {
    overflow: hidden;
  }
  .faq-answer {
    margin: 0;
    padding-bottom: var(--space-xs);
    color: var(--fg-60);
  }
  /* No-JS: show answers in natural flow */
  html:not(.js) .faq-body {
    height: auto !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-body {
      height: auto !important;
    }
  }
  @media (max-width: 768px) {
    .faq {
      flex-direction: column;
      padding: var(--space-2xl) var(--space-3xs) var(--space-2xl);
    }
    .faq-heading {
      padding-right: 0;
    }
    .faq-list {
      width: 100%;
    }
  }
</style>
