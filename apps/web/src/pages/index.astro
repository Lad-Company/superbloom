---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import HomepageComposition from '../components/home/HomepageComposition.astro';
import { sanityClient } from '../lib/sanity';
import { homepageQuery } from '../lib/queries';
import type { HomepageQueryResult } from '../sanity.types';

const homepage: HomepageQueryResult = await sanityClient.fetch(homepageQuery);
const sections = homepage?.sections ?? [];
const navigationRole = sections[0]?._type === 'newsBlock' ? 'dark' : 'light';
---

<Layout>
  <Navigation role={navigationRole} />
  <HomepageComposition sections={sections} />
  <Footer />
</Layout>
