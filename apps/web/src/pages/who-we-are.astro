---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import ContactBand from '../components/ContactBand.astro';
import Marquee from '../components/Marquee.astro';
import FactCardGrid from '../components/FactCardGrid.astro';
import TextMedia from '../components/TextMedia.astro';
import DisciplineList from '../components/DisciplineList.astro';
import TwoUp from '../components/TwoUp.astro';
import Faq from '../components/Faq.astro';
import SurfaceSection from '../components/SurfaceSection.astro';
import WhoWeAreFeaturedMedia from '../components/who-we-are/WhoWeAreFeaturedMedia.astro';
import WhoWeAreHero from '../components/who-we-are/WhoWeAreHero.astro';
import { sanityClient } from '../lib/sanity';
import { whoWeAreQuery } from '../lib/queries';
import type { WhoWeAreQueryResult } from '../sanity.types';

const page = await sanityClient.fetch<WhoWeAreQueryResult>(whoWeAreQuery);

const heroHeading = page?.heroHeading ?? 'Audiences move fast. We help you move faster.';
const introStatement =
  page?.introStatement ??
  'SuperBloom is an independent creative company built to move brands beyond advertising. We bring varied disciplines together powered by a collective of unexpected minds who make unignorable work.';
const marqueeText =
  page?.marquee?.text ??
  'Campaigns. Content. Experiences. branded Entertainment. Social. strategy. creative.';
const featuredMedia = page?.featuredMedia?.media ?? null;
const featuredMediaRatio = page?.featuredMedia?.aspectRatio ?? '16:9';
const statCards = page?.statCards ?? [];
const advantageHeadline = page?.advantageHeadline ?? 'Our unfair advantage';
const advantageBlocks = page?.advantageBlocks ?? [];
const disciplines = page?.disciplines ?? [];
const ctas = page?.ctas ?? [];
const faqs = page?.faqs ?? [];

---

<Layout title="Who We Are" description={introStatement} image={featuredMedia?.asset?._type === 'image' ? featuredMedia.asset.url ?? undefined : undefined}>
  <SurfaceSection role="dark">
    <WhoWeAreHero heading={heroHeading} />
  </SurfaceSection>

  <SurfaceSection role="brand-accent">
    <WhoWeAreFeaturedMedia
      media={featuredMedia}
      ratio={featuredMediaRatio}
      title={heroHeading}
    />
  </SurfaceSection>

  <SurfaceSection role="brand-muted">
    <Marquee text={marqueeText} />
  </SurfaceSection>

  <SurfaceSection role="dark">
    <div class="intro">
      <p class="intro-statement type-h4">{introStatement}</p>
    </div>
  </SurfaceSection>

  {statCards.length > 0 && (
    <FactCardGrid cards={statCards} />
  )}

  <SurfaceSection role="dark">
    <div class="advantage-headline">
      <p class="type-h3">{advantageHeadline}</p>
    </div>
    {advantageBlocks.map((block) => (
      <TextMedia
        heading={block.heading}
        body={block.body ?? null}
        media={block.media ?? null}
        aspectRatio={block.aspectRatio ?? '1:1'}
      />
    ))}
    {advantageBlocks.length === 0 && (
      <TextMedia
        heading="Everyone. Everywhere. All at once."
        body="Moving together from day one, reducing handoffs, speeding up the process, and keeping ideas sharp from concept to launch."
        media={null}
        aspectRatio="1:1"
      />
    )}
  </SurfaceSection>

  {disciplines.length > 0 && (
    <SurfaceSection role="dark">
      <div class="discipline-section">
        <DisciplineList items={disciplines} />
      </div>
    </SurfaceSection>
  )}

  {ctas.length > 0 && (
    <SurfaceSection role="dark">
      <TwoUp items={ctas} />
    </SurfaceSection>
  )}

  {faqs.length > 0 && (
    <SurfaceSection role="dark">
      <Faq items={faqs} />
    </SurfaceSection>
  )}

  <ContactBand role="brand-accent" />
  <Footer />
</Layout>

<style>
  .intro {
    padding: var(--space-4xl) var(--page-inset);
  }
  .intro-statement {
    margin: 0;
    max-width: 24ch;
  }
  .advantage-headline {
    padding: var(--space-4xl) var(--page-inset) 0;
  }
  .advantage-headline p {
    margin: 0;
  }
  .discipline-section {
    padding: var(--space-4xl) 0;
  }
  @media (max-width: 768px) {
    .intro {
      padding: var(--space-2xl) var(--space-3xs);
    }
    .advantage-headline {
      padding: var(--space-2xl) var(--space-3xs) 0;
    }
  }
</style>
