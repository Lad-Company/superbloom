---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import SurfaceSection from '../../components/SurfaceSection.astro';
import ContactBand from '../../components/ContactBand.astro';
import ContentCardList from '../../components/ContentCardList.astro';
import WorkCard from '../../components/WorkCard.astro';
import ProgressiveLoadMore from '../../components/ProgressiveLoadMore.astro';
import { sanityClient } from '../../lib/sanity';
import { workIndexQuery, caseStudiesNewestQuery } from '../../lib/queries';
import type {
  CaseStudiesNewestQueryResult,
  WorkIndexQueryResult,
} from '../../sanity.types';
import type { PartialContentCardSettings } from '../../lib/contentCard';

const BATCH_SIZE = 12;
const requestedPage = Number.parseInt(Astro.url.searchParams.get('page') ?? '1', 10);
const page = Number.isSafeInteger(requestedPage) && requestedPage > 0 ? requestedPage : 1;
const recordLimit = page * BATCH_SIZE;
const workIndex = await sanityClient.fetch<WorkIndexQueryResult>(workIndexQuery);
const featured = workIndex?.featured?.filter((entry) => entry?.item) ?? [];
const featuredIds = featured.map((entry) => entry.item?._id).filter((id): id is string => Boolean(id));
const fetchedCaseStudies = await sanityClient.fetch<CaseStudiesNewestQueryResult>(
  caseStudiesNewestQuery,
  {featuredIds, offset: 0, end: recordLimit + 1}
);
const caseStudies = fetchedCaseStudies.slice(0, recordLimit);
const hasMore = fetchedCaseStudies.length > recordLimit;
const listSettings = workIndex?.allSection?.listDefaults as PartialContentCardSettings;
const globalSettings = workIndex?.globalCardDefaults as PartialContentCardSettings;
const overrideFor = (id: string) =>
  workIndex?.allSection?.itemOverrides?.find((override) => override?.itemId === id) as PartialContentCardSettings;
const queryFor = (nextPage: number) => {
  const params = new URLSearchParams();
  if (nextPage > 1) params.set('page', String(nextPage));
  const search = params.toString();
  return search ? `/work?${search}` : '/work';
};

const heroHeading = workIndex?.heroHeading ?? 'Unexpected minds. Unignorable work.';
const allWorkHeading = 'All Work';

---

<Layout title="Our Work" description={heroHeading}>
  <SurfaceSection role="dark">
    <Navigation role="light" />
    <div class="hero">
      <h1 class="type-h1 hero-heading">{heroHeading}</h1>
    </div>

    {featured.length > 0 && (
      <section class="featured-work" aria-label="Featured work">
        <ContentCardList featured>
          {featured.map((entry) => (
            <WorkCard
              item={entry.item!}
              settings={entry as PartialContentCardSettings}
              globalSettings={globalSettings}
            />
          ))}
        </ContentCardList>
      </section>
    )}

    <div class="all-work">
      <div class="all-work-header">
        <h2 class="type-h3 all-work-heading">{allWorkHeading}</h2>
      </div>
      <ContentCardList class="all-card-list">
        {caseStudies.map((cs) => (
          <WorkCard
            item={cs}
            settings={overrideFor(cs._id)}
            listSettings={listSettings}
            globalSettings={globalSettings}
          />
        ))}
      </ContentCardList>
      {hasMore && <ProgressiveLoadMore href={queryFor(page + 1)} />}
    </div>
  </SurfaceSection>

  <ContactBand role="brand-muted" />
  <Footer />
</Layout>

<style>
  .hero {
    padding: var(--space-2xl) var(--page-inset) 0;
  }
  .hero-heading {
    margin: 0;
    max-width: 21ch;
  }
  .all-work {
    display: grid;
    gap: var(--space-xl);
    min-width: 0;
    padding: var(--space-4xl) var(--page-inset);
  }
  .featured-work {
    display: grid;
    padding: var(--space-xl) var(--page-inset) 0;
  }
  .all-work-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  .all-work-heading {
    margin: 0;
  }
  @media (max-width: 1023px) {
    .hero {
      padding: var(--space-2xl) var(--space-3xs) 0;
    }
    .featured-work,
    .all-work {
      padding-inline: var(--space-3xs);
    }
  }
</style>
