---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import SurfaceSection from '../../components/SurfaceSection.astro';
import ContactBand from '../../components/ContactBand.astro';
import PageGrid from '../../components/PageGrid.astro';
import WorkCard from '../../components/WorkCard.astro';
import { sanityClient } from '../../lib/sanity';
import { workIndexQuery, caseStudiesQuery } from '../../lib/queries';
import type { WorkIndexQueryResult, CaseStudiesQueryResult } from '../../sanity.types';

const [workIndex, caseStudies] = await Promise.all([
  sanityClient.fetch<WorkIndexQueryResult>(workIndexQuery),
  sanityClient.fetch<CaseStudiesQueryResult>(caseStudiesQuery),
]);

const heroHeading = workIndex?.heroHeading ?? 'Unexpected minds. Unignorable work.';
const allWorkHeading = workIndex?.allWorkHeading ?? 'All work';

---

<Layout title="Our Work — Superbloom">
  <SurfaceSection role="dark">
    <Navigation role="dark" />
    <div class="hero">
      <h1 class="type-h1 hero-heading">{heroHeading}</h1>
    </div>

    <div class="all-work">
      <h2 class="type-h3 all-work-heading">{allWorkHeading}</h2>
      <PageGrid>
        {caseStudies.map((cs) => (
          <div class="page-grid-item" data-span={cs.cardSize === 'full' ? 'full' : undefined}>
            <WorkCard item={cs} />
          </div>
        ))}
      </PageGrid>
    </div>
  </SurfaceSection>

  <ContactBand role="brand-muted" />
  <Footer />
</Layout>

<style>
  .hero {
    padding: var(--space-3xl) var(--space-xs) 0;
  }
  .hero-heading {
    margin: 0;
    max-width: 14ch;
  }
  .all-work {
    display: grid;
    gap: var(--space-xl);
    padding: var(--space-4xl) 0;
  }
  .all-work-heading {
    margin: 0;
  }
  @media (max-width: 768px) {
    .hero {
      padding: 120px var(--space-3xs) 0;
    }
    .all-work-heading {
      padding: 0 var(--space-3xs);
    }
  }
</style>
