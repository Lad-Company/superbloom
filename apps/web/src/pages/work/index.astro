---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/case/Section.astro';
import ContactBlock from '../../components/ContactBlock.astro';
import Card from '../../components/Card.astro';
import { sanityClient } from '../../lib/sanity';
import { workIndexQuery, caseStudiesQuery } from '../../lib/queries';
import type { WorkIndexQueryResult, CaseStudiesQueryResult } from '../../sanity.types';

const [workIndex, caseStudies] = await Promise.all([
  sanityClient.fetch<WorkIndexQueryResult>(workIndexQuery),
  sanityClient.fetch<CaseStudiesQueryResult>(caseStudiesQuery),
]);

const heroHeading = workIndex?.heroHeading ?? 'Unexpected minds. Unignorable work.';
const allWorkHeading = workIndex?.allWorkHeading ?? 'All work';

// Pack ordered case studies into rows: a `full` card takes its own row;
// consecutive `half` cards pair two-per-row.
type WorkItem = CaseStudiesQueryResult[number];
const rows: WorkItem[][] = [];
let pending: WorkItem[] = [];
const flush = () => {
  if (pending.length) {
    rows.push(pending);
    pending = [];
  }
};
for (const cs of caseStudies) {
  if ((cs.cardSize ?? 'half') === 'full') {
    flush();
    rows.push([cs]);
  } else {
    pending.push(cs);
    if (pending.length === 2) flush();
  }
}
flush();
---

<Layout title="Our Work — Superbloom">
  <Section theme="dark">
    <Nav state="dark" />
    <div class="hero">
      <h1 class="type-h1 hero-heading">{heroHeading}</h1>
    </div>

    <div class="all-work">
      <h2 class="type-h3 all-work-heading">{allWorkHeading}</h2>
      <div class="rows">
        {rows.map((row) => (
          <div class="row">
            {row.map((cs) => (
              <Card
                href={cs.slug ? `/work/${cs.slug}` : '#'}
                title={cs.title}
                media={cs.media}
                aspectRatio={cs.cardAspectRatio}
                tags={cs.tags}
                summary={cs.summary}
                size="fill"
                showSummary
              />
            ))}
          </div>
        ))}
      </div>
    </div>
  </Section>

  <ContactBlock />
  <Footer />
</Layout>

<style>
  .hero {
    padding: var(--space-3xl) var(--space-xs) 0;
  }
  .hero-heading {
    margin: 0;
    max-width: 14ch;
  }
  .all-work {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    padding: var(--space-4xl) 0;
  }
  .all-work-heading {
    margin: 0;
    padding: 0 var(--space-xs);
  }
  .rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-4xl);
  }
  .row {
    display: flex;
    gap: var(--page-gutter);
    padding: 0 var(--space-xs);
    align-items: flex-start;
  }
  @media (max-width: 768px) {
    .hero {
      padding: 120px var(--space-3xs) 0;
    }
    .all-work-heading,
    .row {
      padding: 0 var(--space-3xs);
    }
    .row {
      flex-direction: column;
    }
  }
</style>
