---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import ContactBand from '../../components/ContactBand.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyComposition from '../../components/case/CaseStudyComposition.astro';
import { sanityClient } from '../../lib/sanity';
import { caseStudyBySlugQuery } from '../../lib/queries';
import type { CaseStudyBySlugQueryResult } from '../../sanity.types';

const { slug } = Astro.params;
const caseStudy: CaseStudyBySlugQueryResult = await sanityClient.fetch(caseStudyBySlugQuery, { slug });

if (!caseStudy) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}
---

<Layout title={`${caseStudy.title} — Superbloom`}>
  <CaseStudyComposition caseStudy={caseStudy}>
    <Navigation slot="navigation" role="surface" />
  </CaseStudyComposition>
  <ContactBand role="brand-deep" />
  <Footer />
</Layout>
