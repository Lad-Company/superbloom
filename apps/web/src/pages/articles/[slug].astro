---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import ContactBand from '../../components/ContactBand.astro';
import ArticleDetail from '../../components/editorial/ArticleDetail.astro';
import {sanityClient} from '../../lib/sanity';
import {editorialArticleBySlugQuery} from '../../lib/queries';

const {slug} = Astro.params;
const article = await sanityClient.fetch(editorialArticleBySlugQuery, {slug});

if (!article) {
  return new Response(null, {status: 404, statusText: 'Not Found'});
}
---

<Layout title={`${article.title} — Superbloom`}>
  <Navigation role="surface" />
  <ArticleDetail article={article} />
  <ContactBand role="brand-deep" />
  <Footer />
</Layout>
