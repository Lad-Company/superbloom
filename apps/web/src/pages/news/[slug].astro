---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import ArticleDetail from '../../components/article/ArticleDetail.astro';
import { sanityClient } from '../../lib/sanity';
import { newsBySlugQuery } from '../../lib/queries';
import type { NewsBySlugQueryResult } from '../../sanity.types';

const { slug } = Astro.params;
const item: NewsBySlugQueryResult = await sanityClient.fetch(newsBySlugQuery, { slug });

if (!item) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

---

<Layout title={`${item.title} — Superbloom`}>
  <Navigation role="dark" />
  <ArticleDetail item={item} />
  <Footer />
</Layout>
