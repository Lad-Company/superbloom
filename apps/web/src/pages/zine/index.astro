---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import ContactBand from '../../components/ContactBand.astro';
import IssueDetail from '../../components/zine/IssueDetail.astro';
import {sanityClient} from '../../lib/sanity';
import {zineLandingQuery} from '../../lib/queries';

const zineLanding = await sanityClient.fetch(zineLandingQuery);

if (!zineLanding?.currentIssue) {
  return new Response(null, {status: 404, statusText: 'Not Found'});
}
---

<Layout title={`${zineLanding.currentIssue.title} — Superbloom Zine`} canonicalUrl="/zine">
  <Navigation role="light" />
  <IssueDetail issue={zineLanding.currentIssue} pastIssues={zineLanding.pastIssues ?? []} />
  <ContactBand role="brand-deep" />
  <Footer />
</Layout>
