---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ContactBand from '../../../components/ContactBand.astro';
import IssueDetail from '../../../components/zine/IssueDetail.astro';
import {sanityClient} from '../../../lib/sanity';
import {issueArchiveQuery, issueBySlugQuery, zineLandingQuery} from '../../../lib/queries';
import {seoDescription, seoImage} from '../../../lib/seo';

const issueSlug = Astro.params.issueSlug;
const issue = await sanityClient.fetch(issueBySlugQuery, {slug: issueSlug});

if (!issue) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const zineLanding = await sanityClient.fetch(zineLandingQuery);

if (issue && zineLanding?.currentIssue?.slug === issue.slug) {
  return Astro.redirect('/zine', 302);
}

const pastIssues = await sanityClient.fetch(issueArchiveQuery, {slug: issue.slug});
---

<Layout
  title={issue.title ?? 'Zine'}
  description={seoDescription(issue.editorLetter?.body)}
  image={seoImage(issue.heroMedia)}
  canonicalUrl={`/zine/issues/${issue.slug}`}
>
  <Navigation role="light" />
  <IssueDetail issue={issue} pastIssues={pastIssues} />
  <ContactBand role="brand-deep" />
  <Footer />
</Layout>
