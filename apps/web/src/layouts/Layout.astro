---
import '../styles/fonts.css';
import '../styles/tokens.css';
import '../styles/motion.css';
import SEOHead from '../components/SEOHead.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
import RouteTransition from '../components/motion/RouteTransition.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  image?: string;
}

const {
  title = 'Superbloom House',
  description = 'Superbloom House helps brands make work people actually want to watch, share, and talk about.',
  canonicalUrl = Astro.url.pathname,
  image,
} = Astro.props;

const canonical = new URL(canonicalUrl, Astro.site ?? Astro.url.origin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOHead title={title} description={description} canonicalUrl={canonical} image={image} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (function () {
        var root = document.documentElement;
        root.classList.add('js');
        try {
          if (sessionStorage.getItem('sbh:route-transition') === '1') {
            root.classList.add('route-entering');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <slot />
    <RouteTransition />
    <CartDrawer />
    <script>
      import { initMotion, initSmoothScroll } from '../lib/motion';
      let destroySmoothScroll = initSmoothScroll();
      initMotion();
      window.addEventListener('pagehide', () => destroySmoothScroll());
      window.addEventListener('pageshow', (event) => {
        if (event.persisted) destroySmoothScroll = initSmoothScroll();
      });
    </script>
    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html {
        -webkit-text-size-adjust: 100%;
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font-body);
        font-size: 19px;
        line-height: 1.3;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      img,
      video {
        display: block;
        max-width: 100%;
      }
      a {
        color: inherit;
      }
      ul {
        margin: 0;
        padding: 0;
        list-style: none;
      }
    </style>
  </body>
</html>
