{
  "name": "studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sanity dev",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "typegen": "sanity schema extract --path schema.json && sanity typegen generate",
    "audit:zine": "sanity exec migrations/audit-zine-membership.ts",
    "backup:zine": "sanity exec migrations/backup-zine-data.ts",
    "backup:index": "sanity exec migrations/backup-index-page-data.ts",
    "migrate:index": "pnpm run backup:index && sanity exec migrations/migrate-index-page.ts",
    "backup:card-carousel": "sanity exec migrations/backup-card-carousel-data.ts",
    "migrate:card-carousel": "pnpm run backup:card-carousel && sanity exec migrations/migrate-card-carousel-data.ts",
    "backup:work": "sanity exec migrations/backup-work-index-data.ts",
    "migrate:work": "pnpm run backup:work && sanity exec migrations/migrate-work-index.ts",
    "migrate:zine": "sanity exec migrations/migrate-zine-issues.ts",
    "migrate:article-body": "sanity exec migrations/migrate-article-body.ts",
    "migrate:case-study-rows": "sanity exec migrations/migrate-case-study-narrative-sections.ts",
    "seed:refresh-source": "sanity exec seed/src/refresh-source.ts",
    "seed:build-manifest": "sanity exec seed/src/build-manifest.ts",
    "seed:retrieve-media": "sanity exec seed/src/retrieve-manifest.ts",
    "typecheck": "tsc -p seed/tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@sanity/color-input": "^5.0.4",
    "@sanity/orderable-document-list": "^1.5.1",
    "@superbloom/schemas": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanity": "^4.0.0",
    "sanity-plugin-mux-input": "^3.0.5",
    "styled-components": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^1.6.1"
  }
}
